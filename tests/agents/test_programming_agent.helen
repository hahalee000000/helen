import "../../agents/contracts/contracts.helen"

test_suite("HelenProgrammer", fn() {
    test_case("完整工作流程执行", fn() {
        let requirement = "实现一个字符串反转函数"
        let project_dir = "/tmp/test_project"
        
        mkdir_p(project_dir + "/src")
        mkdir_p(project_dir + "/tests")
        
        let result = HelenProgrammer(requirement, project_dir)
        
        // 应该完成所有 4 个阶段
        assert_equal(result["status"], "success")
        assert_true(result["phase1_contract"])
        assert_true(result["phase2_tests"])
        assert_true(result["phase3_implementation"])
        assert_true(result["phase4_quality"])
        
        // 应该生成文件
        assert_true(path_exists(project_dir + "/src/string_utils.helen"))
        assert_true(path_exists(project_dir + "/tests/test_string_utils.helen"))
    })

    test_case("质量不达标时回退改进", fn() {
        let requirement = "实现复杂的加密算法"
        let project_dir = "/tmp/test_complex"
        
        mkdir_p(project_dir)
        
        let result = HelenProgrammer(requirement, project_dir)
        
        // 应该有多次迭代
        assert_true(result["iterations"] > 1)
        // 最终质量应该达标
        assert_true(result["final_quality"] >= 7.5)
    })

    test_case("技能评估在任务完成后执行", fn() {
        let requirement = "修复递归函数的栈溢出问题"
        let project_dir = "/tmp/test_skill_learning"
        
        mkdir_p(project_dir)
        
        let result = HelenProgrammer(requirement, project_dir)
        
        // 应该执行技能评估
        assert_true(result["skill_evaluation"])
        // 应该建议创建新技能
        assert_true(len(result["skill_evaluation"]["new_skills"]) > 0)
    })
})
