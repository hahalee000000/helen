// TestBuilder Agent v5 测试
import "../../agents/test_builder.helen"

fn test_test_builder_creation() {
    let builder = TestBuilder("/tmp/src.helen", "/tmp/contract.helen")
    assert_true(builder != null)
}

fn test_test_builder_with_empty_source() {
    let builder = TestBuilder("", "")
    assert_true(builder != null)
}
