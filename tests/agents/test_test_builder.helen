// TestBuilder Agent v5 测试
import "/app/hermes/helen/agents/test_builder.helen"

fn test_test_builder_creation() {
    let builder = TestBuilder("fn add(a, b) { return a + b }", "protocol Math { fn add(a, b): int }")
    assert_true(builder != null)
}

fn test_test_builder_with_empty_source() {
    let builder = TestBuilder("", "protocol Empty { }")
    assert_true(builder != null)
}
