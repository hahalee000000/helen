import "../../agents/contracts/contracts.helen"

test_suite("TestBuilder", fn() {
    test_case("根据契约生成测试", fn() {
        let contract = """
        protocol StringOps {
            fn reverse(s: str): str
        }
        """
        let source = "fn reverse(s: str): str { return \"\" }"
        let result = TestBuilder(source, contract)
        
        assert_true(result["test_count"] >= 3)
        assert_true(contains(result["test_code"], "test_suite"))
        assert_true(contains(result["test_code"], "assert_"))
        assert_equal(result["status"], "success")
    })

    test_case("空源码返回错误", fn() {
        let result = TestBuilder("", "protocol Test { }")
        assert_equal(result["status"], "error")
        assert_equal(result["error_code"], ERR_TEST_GENERATION_FAILED)
    })

    test_case("生成边界条件测试", fn() {
        let contract = """
        protocol Parser {
            fn parse_int(s: str): int
        }
        """
        let source = "fn parse_int(s: str): int { return 0 }"
        let result = TestBuilder(source, contract)
        
        // 应该包含边界测试（空字符串、负数、大数等）
        assert_true(contains(result["test_code"], "边界"))
        assert_true(result["test_count"] >= 5)
    })
})
