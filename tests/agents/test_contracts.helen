import "../../agents/contracts/contracts.helen"

// ── SkillManager Tests ────────────────────────────────────────

fn test_create_rejects_empty_name() {
    let result = skill_create("", "testing", "content")
    assert_equal(result["status"], "error")
    assert_equal(result["error_code"], ERROR_VALIDATION)
}

fn test_create_rejects_invalid_category() {
    let result = skill_create("test-skill", "invalid-cat", "content")
    assert_equal(result["status"], "error")
    assert_equal(result["error_code"], ERROR_VALIDATION)
}

fn test_read_returns_error_for_missing() {
    let result = skill_read("non-existent", "testing")
    assert_equal(result["status"], "error")
    assert_equal(result["error_code"], ERROR_NOT_FOUND)
}

fn test_list_returns_success() {
    let result = skill_list()
    assert_equal(result["status"], "success")
    assert_true(result["count"] >= 0)
}

fn test_is_valid_category_accepts_valid() {
    assert_true(is_valid_category("error-patterns"))
    assert_true(is_valid_category("code-quality"))
    assert_true(is_valid_category("testing"))
    assert_true(is_valid_category("architecture"))
    assert_true(is_valid_category("general"))
}

fn test_is_valid_category_rejects_invalid() {
    assert_true(is_valid_category("invalid") == false)
    assert_true(is_valid_category("") == false)
}

// ── SkillMatcher Tests ────────────────────────────────────────

fn test_extract_keywords_finds_error_kws() {
    let kws = extract_keywords("Division by zero error occurred")
    assert_true(len(kws) > 0)
}

fn test_extract_keywords_empty_for_unrelated() {
    let kws = extract_keywords("hello world")
    assert_equal(len(kws), 0)
}

fn test_match_skills_returns_structure() {
    let result = match_skills("some error context")
    assert_true(result["matches"] != null)
    assert_true(result["keywords"] != null)
}

// ── SkillLearner Tests ────────────────────────────────────────

fn test_determine_category_validation() {
    let result = determine_category({"code": 1, "message": "test"})
    assert_equal(result["category"], "error-patterns")
}

fn test_determine_category_io() {
    let result = determine_category({"code": 101, "message": "test"})
    assert_equal(result["category"], "code-quality")
}

fn test_determine_category_default() {
    let result = determine_category({"code": 999, "message": "test"})
    assert_equal(result["category"], "general")
}

fn test_learn_from_fix_skips_unconfirmed() {
    let result = learn_from_fix({"message": "err"}, "fix", false)
    assert_equal(result["status"], "skipped")
}

fn test_learn_from_fix_rejects_empty() {
    let result = learn_from_fix({"message": "err"}, "", true)
    assert_equal(result["status"], "error")
    assert_equal(result["error_code"], ERROR_VALIDATION)
}

// ── SkillEvolver Tests ────────────────────────────────────────

fn test_evolve_skill_missing_file() {
    let result = evolve_skill("/non/existent/path.md", "finding")
    assert_equal(result["status"], "error")
    assert_equal(result["error_code"], ERROR_NOT_FOUND)
}

// ── Helper Tests ──────────────────────────────────────────────

fn test_skill_path_construction() {
    let path = skill_path("testing", "my-skill")
    assert_equal(path, "agents/skills/testing/my-skill/SKILL.md")
}

fn test_skill_dir_construction() {
    let dir = skill_dir("testing", "my-skill")
    assert_equal(dir, "agents/skills/testing/my-skill")
}

// ── Register Tests ────────────────────────────────────────────

test_suite("SkillManager")
test_case("create rejects empty name", test_create_rejects_empty_name)
test_case("create rejects invalid category", test_create_rejects_invalid_category)
test_case("read returns error for missing", test_read_returns_error_for_missing)
test_case("list returns success", test_list_returns_success)
test_case("is_valid_category accepts valid", test_is_valid_category_accepts_valid)
test_case("is_valid_category rejects invalid", test_is_valid_category_rejects_invalid)
test_end_suite()

test_suite("SkillMatcher")
test_case("extract_keywords finds error keywords", test_extract_keywords_finds_error_kws)
test_case("extract_keywords empty for unrelated", test_extract_keywords_empty_for_unrelated)
test_case("match_skills returns structure", test_match_skills_returns_structure)
test_end_suite()

test_suite("SkillLearner")
test_case("determine_category maps validation errors", test_determine_category_validation)
test_case("determine_category maps IO errors", test_determine_category_io)
test_case("determine_category defaults to general", test_determine_category_default)
test_case("learn_from_fix skips unconfirmed", test_learn_from_fix_skips_unconfirmed)
test_case("learn_from_fix rejects empty fix", test_learn_from_fix_rejects_empty)
test_end_suite()

test_suite("SkillEvolver")
test_case("evolve_skill returns error for missing file", test_evolve_skill_missing_file)
test_end_suite()

test_suite("Helpers")
test_case("skill_path constructs correct path", test_skill_path_construction)
test_case("skill_dir constructs correct directory", test_skill_dir_construction)
test_end_suite()

main {
    let result = run_tests()
    print(result["report"])
}
