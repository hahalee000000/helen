// SkillEvaluator Agent v5 测试
import "../../agents/skill_evaluator.helen"

fn test_skill_evaluator_creation() {
    let evaluator = SkillEvaluator("completed task", "file1.helen, file2.helen")
    assert_true(evaluator != null)
}

fn test_skill_evaluator_with_summary() {
    let summary = "实现了字符串反转函数，使用 TDD 方法"
    let files = "src/string.helen, tests/test_string.helen"
    let evaluator = SkillEvaluator(summary, files)
    assert_true(evaluator != null)
}
