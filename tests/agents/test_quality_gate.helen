// QualityGate Agent v5 测试
import "/app/hermes/helen/agents/quality_gate.helen"

fn test_quality_gate_creation() {
    let gate = QualityGate("/tmp/test.helen", "{}")
    assert_true(gate != null)
}

fn test_quality_gate_with_scores() {
    let before_scores = json_stringify({"overall": 5.0, "security": 6.0})
    let gate = QualityGate("/tmp/test.helen", before_scores)
    assert_true(gate != null)
}
