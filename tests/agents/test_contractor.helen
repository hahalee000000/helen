// Contractor Agent v5 测试
import "../../agents/contractor.helen"

fn test_contractor_creation() {
    let contractor = Contractor("test requirement", "/tmp/test")
    assert_true(contractor != null)
}

fn test_contractor_with_real_requirement() {
    let requirement = "实现一个字符串反转函数"
    let context = "项目: ~/helen, 模块: stdlib/string"
    let contractor = Contractor(requirement, context)
    assert_true(contractor != null)
}
