// Test: 06-llm-statements.md:369

// === Context from preceding blocks ===
agent Translator(text: str, target: str) {
    description "Translate text"
    model "qwen-plus"
    temperature 0.3
    prompt """
    Translate to {{target}}:
    {{text}}
    """

}

fn handle_chunk(chunk) {
    stream_print("[" + chunk + "]")
}

fn handle_chunk(chunk) {
    print(chunk, end="")
}

fn on_done() {
    print("\n\n✅ 流式传输完成")
}

agent Poet(topic: str) {
    description "Write poetry"
    temperature 0.9
    prompt """
    Write a poem about: {{topic}}
    """

}

fn print_chunk(chunk: str) {
    stream_print(chunk)
}

agent Researcher(topic) {
    description "Research assistant"
    tools = ["web_search", "read_file"]
}

// === Test code ===
// 修改文件中的特定函数
llm act "Read /tmp/main.py and change the function name from 'foo' to 'bar'"