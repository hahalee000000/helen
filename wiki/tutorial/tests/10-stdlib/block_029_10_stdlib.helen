// 获取所有压缩事件的审计追踪
let audit = get_compression_audit()
for event in audit {
    print("层级: " + event["layer"])
    print("压缩前: " + str(event["original_token_count"]) + " tokens")
    print("压缩后: " + str(event["compressed_token_count"]) + " tokens")
    print("摘要: " + event["summary"])
}