// Test: 10-stdlib.md:51

// 直接用中文 stdlib 函数名（不需要任何 import 或 alias）
函数 数据处理() {
    设 原始数据 = [3, 1, 4, 1, 5, 9, 2, 6]
    设 排序后 = 排序(原始数据)
    设 去重后 = 去重(排序后)
    返回 长度(去重后)
}

// 中英混用也完全合法
函数 混合使用() {
    let data = [1, 2, 3]
    let sorted = 排序(data)     // 英文变量 + 中文函数
    return len(sorted)          // 切回英文
}

// 处理网络数据
函数 获取数据() {
    设 响应 = http获取("https://api.example.com/data")
    设 解析后 = json解析(响应)
    返回 解析后["name"]
}