}

// === Test code ===
on_media fn(parts, provider) {
    # 仅为非标准 provider 手写
    返回 parts.map(fn(part) {
        返回 {
            "type": "media",
            "mime_type": part.mime,
            "data": 媒体转base64(part),
            "encoding": "base64"
        }
    })
}