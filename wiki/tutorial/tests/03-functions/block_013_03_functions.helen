// Test: 03-functions.md:208

// === Context from preceding blocks ===
fn greet(name) {
    print("Hello, " + name + "!")
}

fn add(a, b) {
    return a + b
}

fn factorial(n: int): int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

let global_x = 100

fn test() {
    let local_x = 200
    print(global_x)    // ✅ 可以访问全局变量
    print(local_x)     // ✅ 可以访问局部变量
}

// === Test code ===
// 闭包捕获外部变量
fn make_adder(x) {
    return fn(y) { return x + y }
}

let add5 = make_adder(5)
print(add5(10))  // 15
print(add5(20))  // 25

// 闭包在实际应用中
fn make_multiplier(factor) {
    return fn(x) { return x * factor }
}

let double = make_multiplier(2)
let triple = make_multiplier(3)

print(double(5))   // 10
print(triple(5))   // 15