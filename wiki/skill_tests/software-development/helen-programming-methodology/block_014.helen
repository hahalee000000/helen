// ✅ 易维护（提取公共函数）
fn validate_input(input: str): map {
    if len(input) == 0 {
        return create_error(1001, "Empty input")
    }
    return create_success(input)
}

fn process_a(input: str): map {
    let validation = validate_input(input)
    if validation["status"] == "error" {
        return validation
    }
    // ... 处理逻辑
