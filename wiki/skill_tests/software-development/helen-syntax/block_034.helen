// 来源: skills/software-development/helen-syntax/SKILL.md (代码块 34)

// 数组索引赋值
let arr = [1, 2, 3]
arr[0] = 10  // ✅ [10, 2, 3]

// 对象字段赋值
let obj = {"name": "Alice"}
obj.name = "Bob"  // ✅ {"name": "Bob"}
obj["age"] = 30   // ✅ {"name": "Bob", "age": 30}

// 嵌套
let matrix = [[1, 2], [3, 4]]
matrix[0][1] = 99  // ✅ [[1, 99], [3, 4]]