// 命令行: helen tool.helen --verbose --output=json input.txt
print(argv)          // ["--verbose", "--output=json", "input.txt"]
print(len(argv))     // 3
print(argv[0])       // "--verbose"

// 也可用 get_cli_args() / parse_cli_args() 进行结构化解析
let config = parse_cli_args()
