// 来源: skills/software-development/helen-language-development/references/environment-and-pitfalls.md (代码块 9)

let count = 0
while (count < 5) {
    print(count)
    count = count + 1    // ✅ assignment — modifies outer variable
    // let count = count + 1    // ❌ new declaration — shadows, causes infinite loop
}