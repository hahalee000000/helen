// 来源: skills/software-development/helen-testing/SKILL.md (代码块 4)

expect(value)
    .toBe(expected)           // 严格相等
    .toEqual(expected)        // 深度相等
    .toContain(item)          // 包含
    .toBeGreaterThan(n)       // 大于
    .toBeLessThan(n)          // 小于
    .toMatch(pattern)         // 正则匹配
    .toStartWith(prefix)      // 开头是
    .toEndWith(suffix)        // 结尾是
    .toHaveLength(n)          // 长度
    .toHaveProperty(key)      // 属性存在
    .toThrow()                // 抛出异常