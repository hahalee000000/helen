{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Helen",
  "scopeName": "source.helen",
  "fileTypes": [".helen"],
  "foldingStartMarker": "\\{",
  "foldingStopMarker": "\\}",
  "patterns": [
    { "include": "#comments" },
    { "include": "#triple-strings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#agents" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.helen",
          "match": "//.*$"
        },
        {
          "name": "comment.block.helen",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.helen",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.helen",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.helen",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.helen" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.helen" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.helen",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.helen",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "triple-strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.helen",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.helen",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.helen",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.helen",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.helen",
          "match": "(?:\\b(?:if|else|for|in|while|break|continue|return|match|case|branch|default|try|catch|finally|throw|assert)\\b|如果|否则|对于|属于|当|中断|继续|匹配|情况|分支|默认|尝试|捕获|最终|抛出|断言)"
        },
        {
          "name": "keyword.declaration.helen",
          "match": "(?:\\b(?:let|const|shared|store|fn|agent|protocol|impl|functions|main|alias|test|expect)\\b|定义|常量|共享|仓库|函数|智能体|协议|实现|函数区|主函|别名|测试|期望)"
        },
        {
          "name": "keyword.other.helen",
          "match": "(?:\\b(?:import|as|call|await|async|llm|act|is|context)\\b|导入|作为|等待|异步|大模型|执行|是|上下文)"
        },
        {
          "name": "keyword.concurrency.helen",
          "match": "(?:\\b(?:spawn|Channel|mailbox_select)\\b|分生|邮箱选择)"
        },
        {
          "name": "keyword.channel.method.helen",
          "match": "(?:\\b(?:send|receive|try_receive|cancel|close)\\b|发送|接收|尝试接收|取消|关闭)"
        },
        {
          "name": "keyword.llm.callback.helen",
          "match": "(?:\\b(?:on_chunk|on_complete|on_tool_end|on_media|on_generate)\\b|逐块处理|完成|工具结束|处理媒体|生成)"
        },
        {
          "name": "keyword.multimodal.helen",
          "match": "(?:\\b(?:media|provider)\\b|媒体)"
        },
        {
          "name": "keyword.agent.property.helen",
          "match": "(?:\\b(?:description|model|tools|temperature|max-turns|streaming|prompt)\\b|描述|模型|工具|温度|最大轮次|流式输出|提示词)"
        },
        {
          "name": "keyword.decoration.helen",
          "match": "(@open|@strict|@sandbox)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.helen",
          "match": "\\b(?:str|int|float|bool|list|dict|map|any|void|number)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.helen",
          "match": "(?:\\btrue\\b|真)"
        },
        {
          "name": "constant.language.boolean.false.helen",
          "match": "(?:\\bfalse\\b|假)"
        },
        {
          "name": "constant.language.null.helen",
          "match": "(?:\\bnull\\b|空)"
        }
      ]
    },
    "agents": {
      "patterns": [
        {
          "name": "meta.agent.helen",
          "begin": "(?:\\b(agent)\\s+([a-zA-Z_][a-zA-Z0-9_]*)|智能体\\s+([a-zA-Z_\\u4e00-\\u9fff][a-zA-Z0-9_\\u4e00-\\u9fff]*))",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.agent.helen" },
            "2": { "name": "entity.name.type.agent.helen" },
            "3": { "name": "keyword.declaration.agent.helen" },
            "4": { "name": "entity.name.type.agent.helen" }
          },
          "end": "(?=\\{)",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.helen",
          "begin": "(?:\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)|函数\\s+([a-zA-Z_\\u4e00-\\u9fff][a-zA-Z0-9_\\u4e00-\\u9fff]*))\\s*\\(",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.function.helen" },
            "2": { "name": "entity.name.function.helen" },
            "3": { "name": "keyword.declaration.function.helen" },
            "4": { "name": "entity.name.function.helen" }
          },
          "end": "\\)",
          "patterns": [
            { "include": "#parameters" }
          ]
        },
        {
          "name": "meta.function.call.helen",
          "match": "\\b([a-zA-Z_\\u4e00-\\u9fff][a-zA-Z0-9_\\u4e00-\\u9fff]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.helen" }
          }
        }
      ]
    },
    "parameters": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_\\u4e00-\\u9fff][a-zA-Z0-9_\\u4e00-\\u9fff]*)\\s*(?=:)",
          "captures": {
            "1": { "name": "variable.parameter.helen" }
          }
        },
        { "include": "#types" }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "(?:\\b(shared\\s+)?(let|const)\\b|(共享)\\s*(定义|常量))\\s+([a-zA-Z_\\u4e00-\\u9fff][a-zA-Z0-9_\\u4e00-\\u9fff]*)",
          "captures": {
            "2": { "name": "keyword.declaration.variable.helen" },
            "3": { "name": "keyword.declaration.variable.helen" },
            "4": { "name": "keyword.declaration.variable.helen" },
            "5": { "name": "variable.other.constant.helen" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.helen",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.helen",
          "match": "===|!==|==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.helen",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.helen",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arrow.helen",
          "match": "=>"
        },
        {
          "name": "keyword.operator.range.helen",
          "match": "\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.helen",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.helen",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.helen",
          "match": "\\."
        },
        {
          "name": "punctuation.section.braces.begin.helen",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.helen",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.helen",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.helen",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.helen",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.helen",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.type.colon.helen",
          "match": ":"
        },
        {
          "name": "keyword.operator.arrow-return.helen",
          "match": "->"
        }
      ]
    }
  }
}
