{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Helen",
  "scopeName": "source.helen",
  "fileTypes": [".helen"],
  "foldingStartMarker": "\\{",
  "foldingStopMarker": "\\}",
  "patterns": [
    { "include": "#comments" },
    { "include": "#triple-strings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#agents" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.helen",
          "match": "//.*$"
        },
        {
          "name": "comment.block.helen",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.helen",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.helen",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.helen",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.helen" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.helen" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.helen",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.helen",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "triple-strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.helen",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.helen",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.helen",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.helen",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.helen",
          "match": "\\b(if|else|for|in|while|break|continue|return|match|case|branch|default|try|catch|finally|throw|assert)\\b"
        },
        {
          "name": "keyword.declaration.helen",
          "match": "\\b(let|const|fn|agent|protocol|impl|functions|main)\\b"
        },
        {
          "name": "keyword.other.helen",
          "match": "\\b(import|as|call|await|async|llm|act|stream|choose|option|is)\\b"
        },
        {
          "name": "keyword.agent.property.helen",
          "match": "\\b(description|model|tools|skills|sub-agents|temperature|max-turns|streaming|prompt)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.helen",
          "match": "\\b(string|int|float|bool|list|dict|any|number|void)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.helen",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.helen",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.helen",
          "match": "\\bnull\\b"
        }
      ]
    },
    "agents": {
      "patterns": [
        {
          "name": "meta.agent.helen",
          "begin": "\\b(agent)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.agent.helen" },
            "2": { "name": "entity.name.type.agent.helen" }
          },
          "end": "(?=\\{)",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.helen",
          "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.function.helen" },
            "2": { "name": "entity.name.function.helen" }
          },
          "end": "\\)",
          "patterns": [
            { "include": "#parameters" }
          ]
        },
        {
          "name": "meta.function.call.helen",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.helen" }
          }
        }
      ]
    },
    "parameters": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": { "name": "variable.parameter.helen" }
          }
        },
        { "include": "#types" }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "\\b(let|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.variable.helen" },
            "2": { "name": "variable.other.constant.helen" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.helen",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.helen",
          "match": "===|!==|==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.helen",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.helen",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arrow.helen",
          "match": "=>"
        },
        {
          "name": "keyword.operator.range.helen",
          "match": "\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.helen",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.helen",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.helen",
          "match": "\\."
        },
        {
          "name": "punctuation.section.braces.begin.helen",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.helen",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.helen",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.helen",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.helen",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.helen",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.type.colon.helen",
          "match": ":"
        },
        {
          "name": "punctuation.definition.arrow.helen",
          "match": "->"
        }
      ]
    }
  }
}
