{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Hellen",
    "scopeName": "source.hellen",
    "fileTypes": [".hellen"],
    "foldingStartMarker": "\\{",
    "foldingStopMarker": "\\}",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#triple-strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#literals"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.hellen",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.double-slash.hellen",
                    "begin": "//",
                    "end": "$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.hellen",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.hellen",
                    "match": "\\\\."
                }
            ]
        },
        "triple-strings": {
            "name": "string.quoted.triple.hellen",
            "begin": "\"\"\"",
            "end": "\"\"\"",
            "patterns": [
                {
                    "name": "constant.character.escape.hellen",
                    "match": "\\\\."
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.hellen",
                    "match": "\\b(if|else|for|while|break|continue|return|match|case|default|in|as|try|catch|finally)\\b"
                },
                {
                    "name": "keyword.control.async.hellen",
                    "match": "\\b(async|await)\\b"
                },
                {
                    "name": "keyword.control.llm.hellen",
                    "match": "\\b(llm|act|choose|branch|option|call)\\b"
                },
                {
                    "name": "storage.type.hellen",
                    "match": "\\b(agent|fn|let|const|import|functions|main)\\b"
                },
                {
                    "name": "storage.modifier.hellen",
                    "match": "\\b(description|model|tools|skills|sub-agents|memory|temperature|max-turns|prompt)\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.language.boolean.hellen",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.null.hellen",
                    "match": "\\bnull\\b"
                },
                {
                    "name": "constant.numeric.integer.hellen",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.float.hellen",
                    "match": "\\b\\d+\\.\\d+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.hellen",
                    "match": "===|!==|==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.arithmetic.hellen",
                    "match": "\\+|-|\\*|/|%|=>"
                },
                {
                    "name": "keyword.operator.logical.hellen",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.assignment.hellen",
                    "match": "="
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.hellen",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\("
                },
                {
                    "name": "variable.other.hellen",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
                }
            ]
        }
    }
}
