{
    "name": "helen-language",
    "displayName": "Helen Language",
    "description": "Helen Agent Programming Language support for VS Code",
    "version": "1.10.0",
    "publisher": "helen-lang",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Snippets"
    ],
    "keywords": [
        "helen",
        "agent",
        "llm",
        "ai",
        "programming language"
    ],
    "activationEvents": [
        "onLanguage:helen"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "helen",
                "aliases": [
                    "Helen",
                    "helen"
                ],
                "extensions": [
                    ".helen"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "helen",
                "scopeName": "source.helen",
                "path": "./syntaxes/helen.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "Helen Language",
            "properties": {
                "helen.lsp.path": {
                    "type": "string",
                    "default": "helen",
                    "description": "Path to the Helen LSP server executable. Default uses 'helen' from PATH."
                },
                "helen.lsp.args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "lsp"
                    ],
                    "description": "Arguments to pass to the Helen LSP server."
                },
                "helen.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable the Helen Language Server."
                },
                "helen.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the Helen language server."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.75.0",
        "@types/node": "^18.x",
        "typescript": "^5.0.0",
        "@vscode/vsce": "^2.22.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/hahalee000000/helen.git"
    },
    "icon": "icon.png",
    "license": "MIT"
}
