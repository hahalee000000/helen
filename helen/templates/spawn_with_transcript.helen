// ═════════════════════════════════════════════════════════════════════
// Template: spawn_with_transcript
// Description: spawn + transcript 继承模式
// Use case: 子 agent 需要访问父 agent 的对话历史
// Key principle: transcript 默认隔离，需要显式继承
// ═════════════════════════════════════════════════════════════════════

// ── Worker Agent ─────────────────────────────────────────────────────
agent Worker(task: str, parent_sid: str, ch: Channel) {
    description "Worker that inherits parent transcript"

    main {
        // 显式恢复父 transcript
        resume_session(parent_sid)

        // 现在可以看到父的对话历史
        let history = replay_transcript()
        print("Inherited " + str(len(history)) + " messages")

        // 执行任务
        let result = llm act task
        ch.send(result)
    }
}

// ── 调用 ─────────────────────────────────────────────────────────────
main {
    // 获取当前 session_id
    let parent_sid = get_session_id()
    print("Parent session: " + parent_sid)

    // 一些对话
    llm act "Remember: the sky is blue"

    // spawn 时显式传递 session_id
    let mailbox = spawn Worker("What color is the sky?", parent_sid)

    let result = mailbox.receive()
    print("Worker result: " + result)
}

// ── 💡 关键点 ────────────────────────────────────────────────────────
// 1. spawn 默认不继承 transcript（独立 session_id）
// 2. 如需继承：显式传递 parent_sid + resume_session
// 3. resume_session 替换当前 transcript store
// 4. 继承后可以看到父的所有对话历史
// 5. 这是"调用者决定上下文"原则的体现
