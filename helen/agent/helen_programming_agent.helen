// Helen Programming Agent
// An interactive AI agent that helps users write, debug, and understand Helen code.
//
// This agent maintains conversation context and provides:
// - Code generation and suggestions
// - Debugging assistance
// - Language feature explanations
// - Best practices guidance

agent HelenProgrammingAgent(conversation: str, docs_path: str, source_dir: str) {
    prompt """You are an expert Helen programming assistant. You help users:

1. Write Helen code (agents, functions, pattern matching, etc.)
2. Debug syntax errors, semantic errors, and runtime errors
3. Understand Helen's unique features (agent blocks, LLM integration, etc.)
4. Follow Helen best practices and idioms

You have access to:
- Complete Helen documentation (tutorial.md)
- Helen source code (parser, interpreter, AST, etc.)
- Conversation history with the user

When responding:
- Be concise and practical
- Provide working code examples
- Explain errors clearly with fix suggestions
- Reference documentation when relevant
- Use the conversation history to maintain context

If the user shows code with errors, identify the issue and provide a corrected version.
If the user asks how to do something, provide a complete working example."""
    
    functions {
        fn load_documentation() -> str {
            let tutorial = read_file(docs_path)
            return tutorial
        }
        
        fn load_source_code() -> str {
            let parser = read_file(source_dir + "core/parser.py")
            let interpreter = read_file(source_dir + "interpreter/interpreter.py")
            let ast = read_file(source_dir + "core/ast.py")
            let lexer = read_file(source_dir + "core/lexer.py")
            
            let sources = "# Helen Source Code\n\n"
            sources = sources + "## Parser (helen/core/parser.py)\n```\n" + parser + "\n```\n\n"
            sources = sources + "## Interpreter (helen/interpreter/interpreter.py)\n```\n" + interpreter + "\n```\n\n"
            sources = sources + "## AST (helen/core/ast.py)\n```\n" + ast + "\n```\n\n"
            sources = sources + "## Lexer (helen/core/lexer.py)\n```\n" + lexer + "\n```\n"
            
            return sources
        }
        
        fn build_context() -> str {
            let docs = load_documentation()
            let sources = load_source_code()
            
            let context = "# Helen Programming Agent\n\n"
            context = context + "You are helping a user write Helen code. Use the conversation history to maintain context.\n\n"
            context = context + "---\n\n"
            context = context + "# Helen Documentation\n\n" + docs + "\n\n"
            context = context + "---\n\n"
            context = context + "# Helen Source Code (for implementation questions)\n\n" + sources + "\n"
            context = context + "---\n\n"
            context = context + "# Conversation History\n\n" + conversation + "\n\n"
            context = context + "---\n\n"
            context = context + "Provide your response below. Be concise, practical, and include code examples when relevant."
            
            return context
        }
    }
    
    main {
        let context = build_context()
        llm stream context
    }
}

// Main entry point (modified by REPL to inject conversation)
main {
    let conversation = ""
    let docs_path = "docs/tutorial.md"
    let source_dir = "helen/"
    HelenProgrammingAgent(conversation, docs_path, source_dir)
}
