// Helen Language Assistant
// An AI-powered assistant that helps users understand Helen,
// write Helen code, and debug Helen programs.
//
// Usage:
//   let answer = HelenAssistant("How do I define an agent?", "/path/to/docs/tutorial.md")
//   print(answer)

agent HelenAssistant(question: str, docs_path: str) {
    prompt """You are an expert Helen language assistant. You help users:
1. Understand Helen syntax and semantics
2. Write Helen code (agents, functions, LLM integration)
3. Debug Helen programs (syntax errors, semantic errors, runtime errors)

Be concise, practical, and provide code examples when relevant.
Reference specific parts of the documentation when answering."""
    
    functions {
        fn load_documentation() -> str {
            // Load Helen tutorial documentation from absolute path
            let tutorial = read_file(docs_path)
            return tutorial
        }
        
        fn build_context() -> str {
            // Build comprehensive context for LLM
            let docs = load_documentation()
            let context = "Helen Language Documentation:\n\n" + docs + "\n\n---\n\nUser question: " + question
            return context
        }
    }
    
    main {
        // Build context with documentation and question
        let context = build_context()
        
        // Use LLM to generate answer
        let answer = llm act context
        
        return answer
    }
}

// Main entry point for standalone execution
main {
    // Example usage (adjust path as needed)
    let question = "How do I define an agent in Helen?"
    let docs_path = "docs/tutorial.md"  // Relative path for development
    let answer = HelenAssistant(question, docs_path)
    print(answer)
}
