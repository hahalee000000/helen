// HelenChat - 循环对话式 AI 助手
// 持续回答用户问题，直到收到 exit 命令退出

agent HelenChat(user_input: str) {
    description "友好的对话式 AI 助手"
    model "qwen3.7-max"
    temperature 0.7
    max-turns 5
    
    prompt """
    你是 HelenChat，一个友好、专业的 AI 助手。
    
    用户输入: {{user_input}}
    
    请用友好、自然的语气回答用户问题。
    保持回答简洁但完整（2-4句话）。
    如果涉及代码，给出简单示例。
    """
    
    functions {
        fn format_response(response: str): str {
            return "🤖 " + response
        }
    }
    
    main {
        let response = llm act user_input
        return format_response(response)
    }
}

main {
    print("🤖 HelenChat - 你的 AI 助手")
    print("输入 'exit' 或 'quit' 退出\n")
    
    while (true) {
        let user_input = input("你: ")
        
        // 检查退出命令
        if (user_input == "exit" || user_input == "quit") {
            print("\n👋 再见！感谢使用 HelenChat")
            break
        }
        
        // 跳过空输入
        if (user_input == "") {
            continue
        }
        
        // 调用 AI 助手
        let response = HelenChat(user_input)
        print(response + "\n")
    }
}
