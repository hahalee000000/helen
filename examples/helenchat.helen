// HelenChat - 对话式 AI 助手
// 循环回答用户问题，直到收到 exit 命令退出

agent HelenChat(user_input: str) {
    description "友好的对话式 AI 助手"
    model "qwen3.7-max"
    temperature 0.7
    max-turns 5
    tools ["read_file", "write_file", "shell_exec"]

    prompt """
    你是 HelenChat，一个友好、专业的 AI 助手。

    用户的问题: {{user_input}}

    请：
    1. 用友好、自然的语气回答
    2. 如果问题不清楚，礼貌地询问更多信息
    3. 提供具体、有用的建议
    4. 如果涉及代码，给出示例
    5. 保持回答简洁但完整
    """

    main {
        let response = llm act
        return response
    }
}

// 主程序 - 对话循环
main {
    print("🤖 HelenChat - 你的 AI 助手")
    print("输入 'exit' 或 'quit' 退出\n")

    while true {
        let user_input = input("你: ")

        // 检查退出命令
        if user_input == "exit" || user_input == "quit" {
            print("\n👋 再见！感谢使用 HelenChat")
            break
        }

        // 跳过空输入
        if len(user_input) == 0 {
            continue
        }

        // 调用 AI 助手
        let response = HelenChat(user_input)
        print("\n🤖 " + response + "\n")
    }
}
