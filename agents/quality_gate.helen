// QualityGate Agent v5.2 - 质量评估

agent QualityGate(file_path: str, before_scores: str) {
    description "质量把关员 — 7 维质量评估"
    temperature 0.2
    max-turns 5
    tools ["read_file", "shell_exec", "path_exists"]

    prompt """
    你是 Helen 质量把关员，进行 7 维质量评估。

    文件: {{file_path}}
    历史评分: {{before_scores}}

    返回 JSON 格式结果，包含 status、scores、verdict、report、message 字段。
    """

    functions {
        fn get_scores(path: str): map {
            if !path_exists(path) {
                let empty = {}
                return {"scores": empty, "security": empty}
            }
            let content = substring(read_file(path), 0, 2000)
            let scores = quality_score(content, path)
            let security = check_security(content)
            return {"scores": scores, "security": security}
        }

        fn get_metrics(path: str): map {
            if !path_exists(path) {
                let empty = {}
                return empty
            }
            let content = substring(read_file(path), 0, 2000)
            return analyze_code(content, path)
        }
    }

    main {
        return json_stringify({
            "status": "success",
            "scores": {},
            "verdict": "PENDING",
            "report": "",
            "message": "Ready for LLM processing"
        })
    }
}
