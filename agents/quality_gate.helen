// QualityGate Agent v5.2 - 质量评估

agent QualityGate(file_path: str, before_scores: str) {
    description "质量把关员 — 对代码进行7维质量评估，提供改进建议"
    temperature 0.2
    max-turns 5
    tools ["read_file", "shell_exec"]

    prompt """
    你是 Helen 质量把关员，对代码进行7维质量评估。

    文件路径: {{file_path}}
    修改前评分: {{before_scores}}

    评估维度（每维度0-10分）:
    1. 安全性 — 输入验证、无注入、秘密保护
    2. 正确性 — 逻辑无误、边界处理、错误码覆盖
    3. 可维护性 — 命名清晰、函数 < 50行、无死代码
    4. 性能 — 无不必要的循环或分配
    5. 可测试性 — 代码易于测试
    6. Helen 规范 — 遵循语言最佳实践
    7. 文档 — 注释完整、接口说明清晰

    工作流程:
    1. 调用 get_scores({{file_path}}) 获取当前评分
    2. 调用 get_metrics({{file_path}}) 获取代码度量
    3. 对比修改前后的变化
    4. 生成质量报告和改进建议

    质量阈值:
    - 单项 < 6.0 → 必须改进（FAIL）
    - 总分 < 7.5 → 建议改进（CONDITIONAL）
    - 总分 ≥ 8.0 → 通过（PASS）

    返回格式（严格遵守）:
    只返回一个合法的 JSON 对象，不要包含 markdown 代码块、解释文字或任何其他内容。
    {
      "status": "success",
      "scores": {
        "security": <0-10>, "correctness": <0-10>, "maintainability": <0-10>,
        "performance": <0-10>, "testability": <0-10>, "helen_compliance": <0-10>,
        "documentation": <0-10>, "overall": <平均分>
      },
      "verdict": "PASS/CONDITIONAL/FAIL",
      "report": "<详细报告文本>"
    }
    """

    functions {
        fn get_scores(path: str): map {
            let content = read_file(path)
            let scores = quality_score(content, path)
            let security = check_security(content)
            return {"scores": scores, "security": security}
        }

        fn get_metrics(path: str): map {
            let content = read_file(path)
            return analyze_code(content, path)
        }
    }

    main {
        // 调用 LLM 进行质量评估；若 LLM 不可用则优雅降级
        let response = ""
        try {
            response = llm act
        } catch {
            response = ""
        }

        // 防御性解析
        let parsed = {"status": "success", "scores": {},
                      "verdict": "PENDING", "report": ""}
        if response != "" {
            try {
                parsed = json_parse(response)
            } catch {
                let parts = split(response, "```json")
                if len(parts) >= 2 {
                    let inner = split(parts[1], "```")
                    try {
                        parsed = json_parse(inner[0])
                    } catch {
                        parsed = {"status": "success", "scores": {},
                                  "verdict": "PENDING", "report": response}
                    }
                } else {
                    parsed = {"status": "success", "scores": {},
                              "verdict": "PENDING", "report": response}
                }
            }
        }
        if parsed["status"] == null { parsed["status"] = "success" }
        if parsed["scores"] == null { parsed["scores"] = {} }
        if parsed["verdict"] == null { parsed["verdict"] = "PENDING" }
        if parsed["report"] == null { parsed["report"] = "" }
        return json_stringify(parsed)
    }
}
