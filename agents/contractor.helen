// Contractor Agent v5.2 - 契约驱动设计

agent Contractor(requirement: str, context: str) {
    description "接口设计师 — 设计 Protocol 接口和函数签名"
    temperature 0.3
    max-turns 5
    tools ["read_file", "write_file", "list_dir", "path_exists"]

    prompt """
    你是 Helen 接口设计师。根据需求设计 Protocol 接口。

    需求: {{requirement}}
    项目: {{context}}

    返回 JSON: {"status":"success","contract":"","modules":[],"message":""}
    """

    functions {
        fn read_existing_contracts(): str {
            let path = context + "/contracts.helen"
            if path_exists(path) {
                return substring(read_file(path), 0, 2000)
            }
            return ""
        }

        fn read_source_files(): map {
            if !path_exists(context) {
                return {"files": [], "error": "dir not found"}
            }
            let files = list_dir(context)
            let result = {"files": []}
            for f in files {
                if endswith(f, ".helen") {
                    result["files"].append(f)
                }
            }
            return result
        }
    }

    main {
        let existing = read_existing_contracts()
        let sources = read_source_files()

        return json_stringify({
            "status": "success",
            "contract": "",
            "modules": [],
            "message": "Ready for LLM processing"
        })
    }
}
