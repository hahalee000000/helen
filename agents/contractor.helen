// Contractor Agent v5.2 - 契约驱动设计

agent Contractor(requirement: str, context: str) {
    description "接口设计师 — 根据需求设计 Protocol 接口和函数签名"
    temperature 0.5
    max-turns 5
    tools ["read_file", "write_file", "list_dir", "path_exists"]

    prompt """
    你是 Helen 接口设计师。根据需求设计清晰的 Protocol 接口。

    需求: {{requirement}}
    上下文: {{context}}

    工作流程:
    1. 调用 read_existing_contracts() 读取现有契约
    2. 调用 read_source_files() 了解项目结构
    3. 设计 Protocol 接口（输入、输出、错误码）
    4. 将契约代码通过 write_file 写入 {{context}}/contracts.helen

    返回格式（严格遵守）:
    只返回一个合法的 JSON 对象，不要包含 markdown 代码块、解释文字或任何其他内容。
    {
      "status": "success",
      "contract": "<完整契约代码>",
      "modules": ["模块1", "模块2"],
      "file_path": "{{context}}/contracts.helen"
    }
    """

    functions {
        fn read_existing_contracts(): str {
            let contracts_file = context + "/contracts.helen"
            if path_exists(contracts_file) {
                return read_file(contracts_file)
            }
            return ""
        }

        fn read_source_files(): map {
            if !path_exists(context) {
                return {"files": [], "error": "context directory not found"}
            }
            let result = {"files": []}
            try {
                let files = list_dir(context)
                for file in files {
                    if endswith(file, ".helen") {
                        result["files"].append(file)
                    }
                }
            } catch {
                // list_dir 失败，返回空列表
            }
            return result
        }
    }

    main {
        // 调用 LLM 进行契约设计；若 LLM 不可用则优雅降级
        let response = ""
        try {
            response = llm act
        } catch {
            response = ""
        }

        // 防御性解析：LLM 可能返回 markdown 包裹的 JSON 或非 JSON 文本
        let parsed = {"status": "success", "contract": "", "modules": [], "file_path": ""}
        if response != "" {
            try {
                parsed = json_parse(response)
            } catch {
                // 尝试从 ```json ... ``` 代码块中提取
                let parts = split(response, "```json")
                if len(parts) >= 2 {
                    let inner = split(parts[1], "```")
                    try {
                        parsed = json_parse(inner[0])
                    } catch {
                        parsed = {"status": "success", "contract": response, "modules": [], "file_path": ""}
                    }
                } else {
                    parsed = {"status": "success", "contract": response, "modules": [], "file_path": ""}
                }
            }
        }
        if parsed["status"] == null { parsed["status"] = "success" }
        if parsed["modules"] == null { parsed["modules"] = [] }
        return json_stringify(parsed)
    }
}
