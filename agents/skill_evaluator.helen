// SkillEvaluator Agent v5.2 - 技能自进化

agent SkillEvaluator(task_summary: str, files_changed: str) {
    description "技能评估员 — 评估可学习的新技能和可优化的技能"
    temperature 0.5
    max-turns 5
    tools ["read_file", "write_file", "shell_exec", "load_skill"]

    prompt """
    你是 Helen 技能评估员。每次编程任务完成后，你负责评估：
    1. 本次任务是否产生了可复用的新模式（→ 新技能）
    2. 现有技能是否遗漏了本次遇到的问题（→ 更新技能）

    任务摘要:
    {{task_summary}}

    修改的文件:
    {{files_changed}}

    工作流程:
    1. 调用 list_existing_skills() 获取现有技能列表
    2. 分析任务摘要，判断是否有新模式值得保存
    3. 检查现有技能是否需要更新（发现新陷阱/新技巧）
    4. 如果确认需要，调用 save_new_skill() 或 update_existing_skill()
    5. 调用 refresh_skill_index() 更新索引

    评估标准:
    - 新技能条件：解决了非平凡问题、发现了新陷阱、建立了可复用模式
    - 更新条件：现有技能遗漏了关键信息、发现了更好的解决方案
    - 不保存条件：简单 typo 修复、一次性配置修改、太泛化无法提取模式

    技能格式要求:
    - YAML frontmatter: name, description, tags, version
    - Markdown body: 触发条件、步骤、代码示例、陷阱
    - tags 使用小写英文关键词
    - 存储位置: ~/.helen/skills/<category>/<name>/SKILL.md

    返回格式（严格遵守）:
    只返回一个合法的 JSON 对象，不要包含 markdown 代码块、解释文字或任何其他内容。
    {
      "status": "success",
      "new_skills": ["<技能1名称>", "<技能2名称>"],
      "updates": ["<更新的技能路径1>"],
      "summary": "<技能评估总结>"
    }
    如果没有新技能或更新，返回空数组即可。
    """

    functions {
        fn list_existing_skills(): list {
            let result = shell_exec("find ~/.helen/skills ~/helen/skills -name 'SKILL.md' 2>/dev/null | head -50")
            return split(result, "\n")
        }

        fn read_skill_content(skill_name: str): str {
            let result = load_skill(skill_name)
            let parsed = json_parse(result)
            if parsed["content"] != null {
                return parsed["content"]
            }
            return ""
        }

        fn save_new_skill(name: str, category: str, tags: str, content: str): map {
            let dir = "~/.helen/skills/" + category + "/" + name
            mkdir_p(dir)
            let frontmatter = "---\n"
                + "name: " + name + "\n"
                + "description: \"" + substring(content, 0, 80) + "\"\n"
                + "tags: " + tags + "\n"
                + "version: 1.0.0\n"
                + "---\n\n"
            write_file(dir + "/SKILL.md", frontmatter + content)
            refresh_skill_index()
            return {"status": "saved", "path": dir}
        }

        fn update_existing_skill(skill_path: str, addition: str): map {
            let content = read_file(skill_path)
            let updated = content + "\n\n" + addition + "\n"
            write_file(skill_path, updated)
            return {"status": "updated", "path": skill_path}
        }

        fn refresh_skill_index(): str {
            let result = shell_exec("find ~/.helen/skills ~/helen/skills -name 'SKILL.md' -exec head -6 {} \\; 2>/dev/null")
            // 把索引写入本地 SKILL_INDEX.md，让用户和后续 agent 都能看到最新目录
            if path_exists("./skills") {
                write_file("./skills/SKILL_INDEX.md", result)
            }
            return result
        }
    }

    main {
        // 调用 LLM 评估可学习技能；若 LLM 不可用则优雅降级
        let response = ""
        try {
            response = llm act
        } catch {
            response = ""
        }

        // 防御性解析
        let parsed = {"status": "success", "new_skills": [],
                      "updates": [], "summary": ""}
        if response != "" {
            try {
                parsed = json_parse(response)
            } catch {
                let parts = split(response, "```json")
                if len(parts) >= 2 {
                    let inner = split(parts[1], "```")
                    try {
                        parsed = json_parse(inner[0])
                    } catch {
                        parsed = {"status": "success", "new_skills": [],
                                  "updates": [], "summary": response}
                    }
                } else {
                    parsed = {"status": "success", "new_skills": [],
                              "updates": [], "summary": response}
                }
            }
        }
        if parsed["status"] == null { parsed["status"] = "success" }
        if parsed["new_skills"] == null { parsed["new_skills"] = [] }
        if parsed["updates"] == null { parsed["updates"] = [] }
        return json_stringify(parsed)
    }
}
