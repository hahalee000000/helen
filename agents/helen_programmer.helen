// ============================================================
// Helen Programming Agent
// A pure-Helen agent for developing, testing, and improving
// Helen programs with TDD and 7-dimension quality assessment.
//
// Usage:
//   helen agents/helen_programmer.helen
// ============================================================

// ── Configuration ────────────────────────────────────────────

const VERSION = "1.0.0"
const QUALITY_THRESHOLD = 7.5
const MAX_ITERATIONS = 5

// ── Code Analyzer Agent ──────────────────────────────────────

agent CodeAnalyzer(source: str, filename: str) {
    description "Analyze Helen source code for quality metrics and security issues"
    model "gpt-4"
    temperature 0.2

    prompt """
    You are a Helen language code analyzer. Given source code, provide:
    1. A brief summary of what the code does
    2. Key observations about code structure
    3. Potential improvements (max 3)

    Be concise. Focus on actionable insights.
    """

    functions {
        fn analyze(src: str) -> map {
            // Use built-in quality tools
            let metrics = analyze_code(src, filename)
            let security = check_security(src)
            let scores = quality_score(src, filename)

            return {
                "metrics": metrics,
                "security_issues": security,
                "scores": scores
            }
        }

        fn format_report(analysis: map) -> str {
            let scores = analysis["scores"]
            let metrics = analysis["metrics"]
            let issues = analysis["security_issues"]

            let report = "=== Code Analysis Report ===\n"
            report = report + "Grade: " + str(scores["grade"]) + " (" + str(scores["total"]) + "/10)\n"
            report = report + "Functions: " + str(metrics["function_count"]) + "\n"
            report = report + "Lines: " + str(metrics["total_lines"]) + "\n"
            report = report + "Comment ratio: " + str(metrics["comment_ratio"]) + "\n"

            if len(issues) > 0 {
                report = report + "Security issues: " + str(len(issues)) + "\n"
                for issue in issues {
                    report = report + "  [" + issue["severity"] + "] " + issue["message"] + "\n"
                }
            }

            return report
        }
    }

    main {
        let analysis = analyze(source)
        let report = format_report(analysis)

        // Use LLM for human-readable insights
        let insights = llm act

        return {
            "analysis": analysis,
            "report": report,
            "insights": insights
        }
    }
}

// ── Test Runner Agent ────────────────────────────────────────

agent TestRunner(test_file: str) {
    description "Run Helen tests and report results"
    model "gpt-4"
    temperature 0.1
    tools ["shell_exec"]

    prompt """
    You are a test runner for the Helen programming language.
    Analyze test output and identify:
    1. Which tests passed/failed
    2. Root causes of failures
    3. Suggested fixes (max 3)

    Be precise and technical.
    """

    functions {
        fn run_tests(file: str) -> map {
            // Run tests via shell and get JSON output
            let cmd = "cd ~/helen && python -c \"from helen.cli.__main__ import main; import sys; main(['test', '" + file + "', '--json'])\" 2>&1"
            let output = shell_exec(cmd)

            // Parse JSON result
            let result = json_parse(output)
            return result
        }

        fn summarize_results(results: map) -> str {
            let total = results["total"]
            let passed = results["passed"]
            let failed = results["failed"]

            let summary = "Tests: " + str(passed) + "/" + str(total) + " passed"

            if failed > 0 {
                summary = summary + ", " + str(failed) + " failed\n"
                for r in results["results"] {
                    let is_passed = r["passed"]
                    if is_passed == false {
                        summary = summary + "  FAIL: " + r["name"] + "\n"
                    }
                }
            }

            return summary
        }
    }

    main {
        let results = run_tests(test_file)
        let summary = summarize_results(results)

        // Use LLM for failure analysis
        let analysis = llm act

        let all_passed = true
        if results["failed"] > 0 {
            all_passed = false
        }

        return {
            "results": results,
            "summary": summary,
            "analysis": analysis,
            "all_passed": all_passed
        }
    }
}

// ── Code Generator Agent ─────────────────────────────────────

agent CodeGenerator(task: str, context: str) {
    description "Generate or modify Helen code based on task description"
    model "gpt-4"
    temperature 0.3
    tools ["read_file", "write_file"]

    prompt """
    You are an expert Helen programmer. Generate clean, well-tested Helen code.

    Rules:
    1. Use snake_case for function names
    2. Add docstrings (// comments) to all functions
    3. Keep functions under 30 lines
    4. Include error handling where appropriate
    5. Follow Helen syntax strictly (no anonymous functions as arguments)

    Task: {{task}}

    Context:
    {{context}}
    """

    main {
        // LLM generates code with tool access
        let result = llm act
        return result
    }
}

// ── Quality Gate Agent ───────────────────────────────────────

agent QualityGate(file_path: str, threshold: float) {
    description "Verify code meets quality threshold"
    model "gpt-4"
    temperature 0.1

    prompt """
    You are a quality gate reviewer. Given quality scores, determine if code
    meets the threshold and suggest specific improvements if not.

    Be strict but fair. Focus on the lowest-scoring dimensions.
    """

    functions {
        fn check_quality(path: str) -> map {
            let source = read_file(path)
            let scores = quality_score(source, path)
            let passes = false
            if scores["total"] >= threshold {
                passes = true
            }

            return {
                "scores": scores,
                "passes": passes,
                "threshold": threshold,
                "gap": threshold - scores["total"]
            }
        }
    }

    main {
        let result = check_quality(file_path)

        if result["passes"] == true {
            return {
                "status": "PASS",
                "message": "Quality score " + str(result["scores"]["total"]) + " meets threshold " + str(threshold),
                "scores": result["scores"]
            }
        }

        // Use LLM for improvement suggestions
        let suggestions = llm act

        return {
            "status": "FAIL",
            "message": "Quality score " + str(result["scores"]["total"]) + " below threshold " + str(threshold),
            "gap": result["gap"],
            "scores": result["scores"],
            "suggestions": suggestions
        }
    }
}

// ── Helper Functions ─────────────────────────────────────────

fn analyze_current_state(file: str) -> map {
    // Check if file exists
    let exists = path_exists(file)

    if exists == false {
        return {
            "exists": false,
            "source": "",
            "analysis": null
        }
    }

    let source = read_file(file)
    let analysis = CodeAnalyzer(source=source, filename=file)
    return {
        "exists": true,
        "source": source,
        "analysis": analysis
    }
}

fn generate_tests(file: str, task_desc: str) -> str {
    let dir = path_dirname(file)
    let base = path_basename(file)
    let test_file = dir + "/test_" + base

    let source = ""
    if path_exists(file) {
        source = read_file(file)
    }

    let context = "Existing code:\n" + source + "\n\nTask: " + task_desc
    let generated = CodeGenerator(task="Write tests for: " + task_desc, context=context)

    write_file(test_file, generated)
    return test_file
}

fn run_quality_check(file: str) -> map {
    return QualityGate(file_path=file, threshold=QUALITY_THRESHOLD)
}

fn iterate_improve(file: str, feedback: str, iteration: int) -> str {
    let source = read_file(file)
    let context = "Current code:\n" + source + "\n\nFeedback:\n" + feedback + "\n\nIteration: " + str(iteration)

    let improved = CodeGenerator(
        task="Improve code based on feedback",
        context=context
    )

    write_file(file, improved)
    return improved
}

// ── Main Orchestrator ────────────────────────────────────────

agent HelenProgrammer(task: str, target_file: str) {
    description "Orchestrate Helen program development with TDD and quality gates"
    model "gpt-4"
    temperature 0.2
    max-turns 10
    tools ["read_file", "write_file", "shell_exec"]

    prompt """
    You are the Helen Programming Agent orchestrator. Your job:
    1. Analyze the current state of the target file
    2. Understand the task requirements
    3. Generate or modify code to fulfill the task
    4. Verify tests pass
    5. Verify quality meets threshold ({{threshold}})
    6. Iterate if needed (max {{max_iter}} iterations)

    Always use the available tools to read/write files and run commands.
    """

    main {
        print("🚀 Helen Programmer starting...")
        print("   Task: " + task)
        print("   Target: " + target_file)
        print("")

        // Phase 1: Analyze current state
        print("📊 Phase 1: Analyzing current state...")
        let state = analyze_current_state(target_file)

        if state["exists"] == true {
            print("   File exists, analyzing...")
            let report = state["analysis"]["report"]
            print(report)
        } else {
            print("   File does not exist, will create new.")
        }

        // Phase 2: Generate/modify code
        print("")
        print("🔨 Phase 2: Generating/modifying code...")
        let context = ""
        if state["exists"] == true {
            context = state["source"]
        }

        let generated = CodeGenerator(task=task, context=context)
        write_file(target_file, generated)
        print("   Code written to " + target_file)

        // Phase 3: Generate tests
        print("")
        print("🧪 Phase 3: Generating tests...")
        let test_file = generate_tests(target_file, task)
        print("   Tests written to " + test_file)

        // Phase 4: Run tests
        print("")
        print("▶ Phase 4: Running tests...")
        let test_result = TestRunner(test_file=test_file)
        print("   " + test_result["summary"])

        // Phase 5: Quality gate
        print("")
        print("🔍 Phase 5: Quality gate...")
        let quality = run_quality_check(target_file)
        print("   Status: " + quality["status"])
        print("   Score: " + str(quality["scores"]["total"]) + "/10")

        // Phase 6: Iterate if needed
        let iteration = 0
        let needs_improvement = true
        if quality["status"] == "PASS" {
            needs_improvement = false
        }

        while needs_improvement == true {
            if iteration >= MAX_ITERATIONS {
                needs_improvement = false
            } else {
                iteration = iteration + 1
                print("")
                print("🔄 Iteration " + str(iteration) + ": Improving code...")

                let feedback = quality["suggestions"]
                if test_result["all_passed"] == false {
                    feedback = feedback + "\n\nTest failures:\n" + test_result["analysis"]
                }

                iterate_improve(target_file, feedback, iteration)

                // Re-run tests
                test_result = TestRunner(test_file=test_file)
                print("   " + test_result["summary"])

                // Re-check quality
                quality = run_quality_check(target_file)
                print("   Quality: " + str(quality["scores"]["total"]) + "/10")

                if quality["status"] == "PASS" {
                    needs_improvement = false
                }
            }
        }

        // Final report
        print("")
        print("============================================================")
        if quality["status"] == "PASS" {
            print("✅ SUCCESS! Code meets quality threshold.")
        } else {
            print("⚠️  WARNING: Could not reach quality threshold after " + str(MAX_ITERATIONS) + " iterations.")
            print("   Final score: " + str(quality["scores"]["total"]) + "/10")
        }
        print("============================================================")

        return {
            "file": target_file,
            "test_file": test_file,
            "quality": quality,
            "tests": test_result,
            "iterations": iteration
        }
    }
}

// ── Entry Point ──────────────────────────────────────────────

main {
    // Default task for demonstration
    let task = "Create a calculator module with add, subtract, multiply, divide functions. Include input validation and error handling."
    let target = "examples/calculator.helen"

    // Run the programmer agent
    let result = HelenProgrammer(task=task, target_file=target)

    print("")
    print("Result:")
    print("  File: " + result["file"])
    print("  Tests: " + result["test_file"])
    print("  Iterations: " + str(result["iterations"]))
    print("  Final grade: " + result["quality"]["scores"]["grade"])
}
