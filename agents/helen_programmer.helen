// HelenProgrammer Agent v5.2 - 主编排器

import "/app/hermes/helen/agents/contractor.helen"
import "/app/hermes/helen/agents/test_builder.helen"
import "/app/hermes/helen/agents/implementer.helen"
import "/app/hermes/helen/agents/quality_gate.helen"
import "/app/hermes/helen/agents/skill_evaluator.helen"

agent HelenProgrammer(requirement: str, project_dir: str) {
    description "Helen 编程助手主编排"
    temperature 0.2
    max-turns 10
    tools ["read_file", "write_file", "shell_exec", "mkdir_p", "path_exists"]

    prompt """
    你是 Helen 编程助手主编排。协调 5 个 Agent 完成：
    1. Contractor - 契约设计
    2. TestBuilder - 测试生成
    3. Implementer - TDD 实现
    4. QualityGate - 质量评估
    5. SkillEvaluator - 技能进化

    需求: {{requirement}}
    项目: {{project_dir}}
    """

    functions {
        fn run_helen_check(file_path: str): map {
            if !path_exists(file_path) {
                return {"output": "", "valid": false}
            }
            let result = shell_exec("helen check " + file_path + " 2>&1")
            return {"output": substring(result, 0, 500), "valid": contains(result, "OK")}
        }

        fn run_helen_tests(test_dir: str): map {
            if !path_exists(test_dir) {
                return {"output": "", "success": false}
            }
            let result = shell_exec("helen test " + test_dir + " 2>&1", timeout=60)
            return {"output": substring(result, 0, 500), "success": contains(result, "ALL TESTS PASSED")}
        }

        fn call_contractor(req: str, ctx: str): map {
            return json_parse(Contractor(req, ctx))
        }

        fn call_test_builder(src: str, ctr: str): map {
            return json_parse(TestBuilder(src, ctr))
        }

        fn call_implementer(src: str, tst: str, ctr: str): map {
            return json_parse(Implementer(src, tst, ctr))
        }

        fn call_quality_gate(path: str, before: str): map {
            return json_parse(QualityGate(path, before))
        }

        fn call_skill_evaluator(summary: str, files: str): map {
            return json_parse(SkillEvaluator(summary, files))
        }
    }

    main {
        let src = project_dir + "/src/main.helen"
        let ctr = project_dir + "/contracts/contracts.helen"
        let tst = project_dir + "/tests/test_main.helen"

        let c = call_contractor(requirement, project_dir)
        let t = call_test_builder(src, ctr)
        let i = call_implementer(src, tst, ctr)
        let q = call_quality_gate(src, "{}")
        let s = call_skill_evaluator(requirement, src + "," + tst)

        return json_stringify({
            "status": "success",
            "phases": {"contract": c, "test": t, "implement": i, "quality": q, "skill": s}
        })
    }
}
