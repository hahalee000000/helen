// ============================================================
// Helen Programming Agent — 主编排智能体
//
// 垂直于 Helen 编程的自进化智能体，具备：
// - 技能自进化（从成功修复中学习）
// - 代码感知（读取项目文件、理解 AST）
// - 测试驱动（自动跑测试、建议修复）
// - 质量评估（7 维质量分析）
//
// 使用契约优先设计，复用 agents/contracts/contracts.helen
// ============================================================

// ── 导入契约 ─────────────────────────────────────────────────

import "contracts/contracts.helen"

// ── Agent 定义 ────────────────────────────────────────────────

agent HelenProgrammer(project_dir: str, user_input: str) {
    description """你是 Helen 编程助手，专注于辅助 Helen 语言开发。

你的核心能力：
1. 代码生成：根据需求生成符合 Helen 语法的代码
2. 错误诊断：分析语法错误、语义错误、运行时错误
3. 质量改进：提供 7 维质量分析和改进建议
4. 技能复用：从技能库中搜索已知模式，避免重复解决问题

工作流程：
1. 分析用户输入，提取关键词
2. 搜索技能库（agents/skills/）匹配已知模式
3. 如果匹配到技能，优先复用已知方案
4. 如果没有匹配，使用 LLM 推理解决
5. 解决后，如果用户确认成功，提取新模式保存为技能

项目目录: {{project_dir}}
用户输入: {{user_input}}
"""
    
    model "gpt-4"
    temperature 0.2
    max-turns 10
    streaming true
    
    tools ["read_file", "write_file", "exec", "path_exists", "analyze_code", "quality_score", "check_security"]

    functions {
        // ── 技能搜索 ──────────────────────────────────────────
        
        fn search_skills(context: str) -> list {
            let index_path = "agents/skills/SKILL_INDEX.md"
            if path_exists(index_path) == false {
                return []
            }
            
            let index_content = read_file(index_path)
            let keywords = extract_keywords(context)
            let matches = []
            
            for kw in keywords {
                if regex_test(index_content, "(?i)" + kw) {
                    matches.append(kw)
                }
            }
            
            return matches
        }
        
        fn extract_keywords(context: str) -> list {
            let keywords = []
            let lower = context.lower()
            
            // 错误类型关键词
            let error_kws = ["division", "zero", "error", "exception", "fail", "crash", "null", "index"]
            for kw in error_kws {
                if regex_test(lower, kw) {
                    keywords.append(kw)
                }
            }
            
            // 质量关键词
            let quality_kws = ["complexity", "quality", "score", "metric", "security"]
            for kw in quality_kws {
                if regex_test(lower, kw) {
                    keywords.append(kw)
                }
            }
            
            // 测试关键词
            let test_kws = ["test", "assert", "coverage", "pytest"]
            for kw in test_kws {
                if regex_test(lower, kw) {
                    keywords.append(kw)
                }
            }
            
            // 去重
            let unique = []
            for kw in keywords {
                let is_dup = false
                for existing in unique {
                    if existing == kw {
                        is_dup = true
                    }
                }
                if is_dup == false {
                    unique.append(kw)
                }
            }
            
            return unique
        }
        
        fn load_skill(skill_name: str) -> str {
            // 尝试不同类别
            let categories = ["error-patterns", "code-quality", "testing", "architecture", "general"]
            for cat in categories {
                let skill_path = "agents/skills/" + cat + "/" + skill_name + "/SKILL.md"
                if path_exists(skill_path) {
                    return read_file(skill_path)
                }
            }
            return ""
        }
        
        // ── 代码分析 ──────────────────────────────────────────
        
        fn analyze_file(file_path: str) -> map {
            if path_exists(file_path) == false {
                return {"status": "error", "message": "file not found: " + file_path}
            }
            
            let source = read_file(file_path)
            let metrics = analyze_code(source, file_path)
            let security = check_security(source)
            let scores = quality_score(source, file_path)
            
            return {
                "status": "success",
                "metrics": metrics,
                "security": security,
                "scores": scores
            }
        }
        
        // ── 测试执行 ──────────────────────────────────────────
        
        fn run_tests(dir: str) -> map {
            let cmd = "cd " + dir + " && bash scripts/run_tests_batch.sh 2>&1"
            let result = exec(cmd, true)
            let output = result["stdout"]
            
            let passed = 0
            let failed = 0
            let total = 0
            
            if regex_test(output, "All tests passed") {
                passed = 1
                total = 1
            }
            
            return {
                "status": "success",
                "output": output,
                "passed": passed,
                "failed": failed,
                "total": total,
                "success": result["returncode"] == 0
            }
        }
        
        // ── 技能保存 ──────────────────────────────────────────
        
        fn save_skill(name: str, category: str, content: str) -> map {
            let dir = "agents/skills/" + category + "/" + name
            let path = dir + "/SKILL.md"
            
            if path_exists(path) {
                return {"status": "error", "message": "skill already exists: " + name}
            }
            
            let mkdir_result = exec("mkdir -p " + dir, true)
            if mkdir_result["returncode"] != 0 {
                return {"status": "error", "message": "failed to create directory"}
            }
            
            let write_result = write_file(path, content)
            if write_result == false {
                return {"status": "error", "message": "failed to write skill file"}
            }
            
            // 更新索引
            update_skill_index()
            
            return {"status": "success", "message": "Skill saved: " + name, "path": path}
        }
        
        fn update_skill_index() -> void {
            let cmd = "cd ~/helen && find agents/skills -name 'SKILL.md' -exec head -10 {} \\;"
            let result = exec(cmd, true)
            write_file("agents/skills/SKILL_INDEX.md", result["stdout"])
        }
    }

    main {
        // 1. 搜索已有技能
        let matched_skills = search_skills(user_input)
        
        if len(matched_skills) > 0 {
            print("📚 Found " + str(len(matched_skills)) + " matching skill(s)")
            let skill_content = load_skill(matched_skills[0])
            if skill_content != "" {
                print("📖 Using skill: " + matched_skills[0])
                // 使用技能内容辅助 LLM
            }
        }
        
        // 2. LLM 推理（结合技能上下文）
        let response = llm act
        
        // 3. 输出结果
        print(response)
        
        return response
    }
}

// ── 主入口 ────────────────────────────────────────────────────

main {
    // 默认参数（REPL 会覆盖）
    let project_dir = "."
    let user_input = "How do I define an agent in Helen?"
    
    let result = HelenProgrammer(project_dir, user_input)
    print(result)
}
