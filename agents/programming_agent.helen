// ============================================================
// Programming Agent — Main Orchestrator (v2.0)
// 
// Coordinates all sub-agents to provide Helen programming
// assistance with self-evolving skill system.
//
// Uses Helen v1.5 features:
// - functions block variables (let/const in agent functions)
// - list methods (append, extend, etc.)
// - match range patterns
//
// Workflow:
// 1. Load agent memory
// 2. Search skills for matching patterns
// 3. If skill matched: use skill to guide response
// 4. If no skill: use LLM reasoning
// 5. If code fix applied: run tests + quality check
// 6. If fix successful: offer to save as new skill
// 7. Update agent memory
// ============================================================

// ── Helper Functions ──────────────────────────────────────────

// Note: Contract functions are defined in agents/contracts/contracts.helen
// For now, we duplicate the needed functions here until Helen supports
// module-level imports properly.

fn get_memory_path() -> str {
    return "agents/memory/MEMORY.md"
}

fn get_user_path() -> str {
    return "agents/memory/USER.md"
}

fn load_memory() -> str {
    let path = get_memory_path()
    if path_exists(path) {
        return read_file(path)
    }
    return ""
}

fn load_user_profile() -> str {
    let path = get_user_path()
    if path_exists(path) {
        return read_file(path)
    }
    return ""
}

fn update_memory(new_entry: str) -> str {
    let path = get_memory_path()
    let current = ""
    if path_exists(path) {
        current = read_file(path)
    }
    let updated = current + "\n- " + new_entry
    write_file(path, updated)
    return "Memory updated"
}

fn analyze_helen_code(file_path: str) -> map {
    // Analyzes a Helen source file using quality tools
    if path_exists(file_path) == false {
        return {"error": "File not found: " + file_path}
    }
    
    let source = read_file(file_path)
    let metrics = analyze_code(source, file_path)
    let security = check_security(source)
    let scores = quality_score(source, file_path)
    
    return {
        "metrics": metrics,
        "security": security,
        "scores": scores,
        "source": source
    }
}

fn run_project_tests(project_dir: str) -> map {
    // Runs tests for a project
    let cmd = "cd " + project_dir + " && bash scripts/run_tests_batch.sh 2>&1"
    let result = exec(cmd, true)
    let output = result["stdout"]
    
    // Parse output for test counts
    let passed = 0
    let failed = 0
    
    if regex_search(output, "All tests passed") {
        passed = 1  // Simplified: just check if tests passed
    }
    
    return {
        "output": output,
        "passed": passed,
        "failed": failed,
        "success": result["returncode"] == 0
    }
}

// Skill search implementation (mirrors contracts.helen)
fn search_skills_for_context(context: str) -> map {
    let keywords = []
    let lower_context = context.lower()
    
    // Extract keywords
    let error_keywords = ["division", "zero", "error", "exception", "fail", "crash"]
    for kw in error_keywords {
        if regex_search(lower_context, kw) {
            keywords.append(kw)
        }
    }
    
    let quality_keywords = ["complexity", "quality", "score", "metric", "security"]
    for kw in quality_keywords {
        if regex_search(lower_context, kw) {
            keywords.append(kw)
        }
    }
    
    let test_keywords = ["test", "assert", "coverage", "pytest"]
    for kw in test_keywords {
        if regex_search(lower_context, kw) {
            keywords.append(kw)
        }
    }
    
    // Search skill index
    let index_path = "agents/skills/SKILL_INDEX.md"
    if path_exists(index_path) == false {
        return {"matches": [], "keywords": keywords, "count": 0}
    }
    
    let index = read_file(index_path)
    let matches = []
    for kw in keywords {
        if regex_search(index, "(?i)" + kw) {
            matches.append({"keyword": kw, "found": true})
        }
    }
    
    return {
        "matches": matches,
        "keywords": keywords,
        "count": len(matches)
    }
}

// ── Programming Agent ─────────────────────────────────────────

agent ProgrammingAgent(project_dir: str, user_input: str) {
    description "Main orchestrator for Helen programming assistance"
    model "gpt-4"
    temperature 0.2
    max-turns 10
    tools ["read_file", "write_file", "exec"]

    prompt """
    You are the Helen Programming Agent, a self-evolving AI assistant
    specialized in Helen language development.
    
    Project Directory: {{project_dir}}
    User Input: {{user_input}}
    
    Your capabilities:
    1. Search skill library for known patterns
    2. Analyze code quality (7-dimension framework)
    3. Run tests and verify fixes
    4. Learn from successful fixes (save as new skills)
    5. Evolve existing skills with new findings
    
    Workflow:
    1. Load agent memory for context
    2. Search skills for matching patterns
    3. If skill matched: use it to guide response
    4. If no skill: use LLM reasoning
    5. If code fix applied: verify with tests + quality check
    6. If successful: offer to save as new skill
    
    Always use Helen's built-in tools:
    - analyze_code() for metrics
    - quality_score() for 7-dimension scoring
    - check_security() for security analysis
    - helen test for running tests
    """

    // v1.5: functions block variables
    functions {
        const AGENT_VERSION = "2.0"
        const MAX_SKILL_RESULTS = 10
        
        fn get_memory_content() -> str {
            return load_memory()
        }

        fn get_user_content() -> str {
            return load_user_profile()
        }

        fn search_skills_ctx(context: str) -> map {
            return search_skills_for_context(context)
        }

        fn build_context_str(project: str, mem: str, usr: str, skill_map: map) -> str {
            let ctx = "Project: " + project + "\n"
            ctx = ctx + "Memory: " + mem + "\n"
            ctx = ctx + "User Profile: " + usr + "\n"
            ctx = ctx + "Matched Skills: " + str(skill_map["count"]) + "\n"
            return ctx
        }

        fn process_request(project_dir: str, user_input: str) -> map {
            let mem = get_memory_content()
            let usr = get_user_content()
            let skill_map = search_skills_ctx(user_input)
            let ctx = build_context_str(project_dir, mem, usr, skill_map)
            
            return {
                "memory": mem,
                "user_profile": usr,
                "skill_matches": skill_map,
                "context": ctx
            }
        }

        fn analyze_file(file_path: str) -> map {
            return analyze_helen_code(file_path)
        }

        fn generate_report(file_path: str, analysis: map) -> str {
            let scores = analysis["scores"]
            let report = "Quality Report for " + file_path + ":\n"
            report = report + "  Total Score: " + str(scores["total"]) + "/10\n"
            report = report + "  Grade: " + scores["grade"] + "\n"
            report = report + "  Architecture: " + str(scores["architecture"]) + "\n"
            report = report + "  Code Quality: " + str(scores["code_quality"]) + "\n"
            report = report + "  Security: " + str(scores["security"]) + "\n"
            report = report + "  Test Coverage: " + str(scores["test_coverage"]) + "\n"
            report = report + "  Documentation: " + str(scores["documentation"]) + "\n"
            report = report + "  Maintainability: " + str(scores["maintainability"]) + "\n"
            report = report + "  Engineering: " + str(scores["engineering"]) + "\n"
            return report
        }

        fn save_skill_from_fix(error_info: map, fix: str) -> map {
            return save_as_skill(error_info, fix)
        }
        
        fn get_version() -> str {
            return AGENT_VERSION
        }
    }

    main {
        // Process the request
        let context = process_request(project_dir, user_input)
        
        // Use LLM to generate response
        let response = llm act
        
        // Return result
        return {
            "response": response,
            "context": context,
            "project_dir": project_dir,
            "version": get_version()
        }
    }
}

// ── Entry Point ───────────────────────────────────────────────

main {
    // Example usage
    let project = "~/helen"
    let task = "How do I fix a division by zero error?"
    
    let result = ProgrammingAgent(project_dir=project, user_input=task)
    
    print("Helen Programming Agent v" + result["version"])
    print("===========================")
    print("Project: " + result["project_dir"])
    print("")
    print(result["response"])
}
