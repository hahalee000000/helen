// ============================================================
// Helen Programming Agent — Main Entry Point
//
// Pure Helen language implementation of a self-evolving
// programming assistant with skill management.
//
// NEW ARCHITECTURE: Functions in the `functions` block are
// automatically exposed as LLM-callable tools. The LLM can
// invoke these functions directly during reasoning.
//
// Usage:
//   helen agents/programming_agent.helen
//   // Or from REPL: :agent agents/programming_agent.helen
// ============================================================

import "contracts/contracts.helen"

agent HelenProgrammingAgent(project_dir: str, user_input: str) {
    description "Helen 编程助手 — 具备技能自进化能力的垂直 Copilot"
    model "gpt-4"
    temperature 0.2
    max-turns 10
    streaming true
    // Note: `tools` declaration is now optional. Functions in the
    // `functions` block are automatically exposed as LLM tools.
    // You can still use `tools` to add Python built-in tools.
    tools ["read_file", "write_file", "shell_exec", "patch_file", "calculate", "load_skill"]

    prompt """
    你是 Helen 编程助手，专注于辅助 Helen 语言开发。

    项目目录: {{project_dir}}
    用户输入: {{user_input}}

    你的工作流程：
    1. 搜索技能库（agents/skills/）匹配已知模式
    2. 如果匹配到技能，优先复用已知修复方案
    3. 如果没有匹配，用 LLM 推理解决
    4. 解决后，如果用户确认成功，提取新模式保存为技能
    5. 更新 Agent 记忆（agents/memory/MEMORY.md）

    技能存储位置: agents/skills/（全局，跨项目共享）
    技能格式: SKILL.md (YAML frontmatter + Markdown)

    你可以调用以下工具函数（定义在 functions 块中）：
    - search_skills(context: str): 搜索匹配的技能
    - load_skill_content(name: str, category: str): 加载技能内容
    - save_skill(name: str, category: str, content: str): 保存新技能
    - analyze_and_fix(file: str, error_msg: str): 分析文件并建议修复
    - run_tests_for_project(dir: str): 运行项目测试
    - learn_from_interaction(error: map, fix: str, confirmed: bool): 从修复中学习
    - get_agent_context(): 获取 agent 上下文（记忆 + 技能摘要）
    """

    // Functions in this block are automatically exposed as LLM-callable tools.
    // The LLM can invoke them during reasoning via function calling.
    functions {
        fn search_skills(context: str) -> list {
            let result = match_skills(context)
            // Use map with lambda to extract keywords
            let matched = map(result["matches"], fn(item) {
                return item["keyword"]
            })
            return matched
        }

        fn load_skill_content(name: str, category: str) -> str {
            let result = skill_read(name, category)
            if result["status"] == "success" {
                return result["content"]
            }
            return ""
        }

        fn save_skill(name: str, category: str, content: str) -> str {
            let result = skill_create(name, category, content)
            if result["status"] == "success" {
                update_skill_index()
                return "Skill saved: " + result["path"]
            }
            return "Failed to save skill: " + result["message"]
        }

        fn analyze_and_fix(file: str, error_msg: str) -> map {
            if !path_exists(file) {
                return {"error": "file not found: " + file}
            }

            let source = read_file(file)
            let metrics = analyze_code(source, file)
            let security = check_security(source)
            let scores = quality_score(source, file)

            // Search for matching skills
            let matched = search_skills(error_msg)

            return {
                "metrics": metrics,
                "security": security,
                "scores": scores,
                "matched_skills": matched,
                "error_context": error_msg
            }
        }

        fn run_tests_for_project(dir: str) -> map {
            return run_project_tests(dir)
        }

        fn learn_from_interaction(error: map, fix: str, confirmed: bool) -> map {
            return learn_from_fix(error, fix, confirmed)
        }

        fn get_agent_context() -> str {
            let context = ""
            if path_exists(MEMORY_PATH) {
                context = read_file(MEMORY_PATH)
            }
            let skill_summary = skill_list()
            return "Memory:\n" + context + "\n\nSkills: " + str(skill_summary["count"]) + " available"
        }
    }

    main {
        // 1. Load agent context (memory + skill count)
        let context = get_agent_context()

        // 2. Search for matching skills
        let matched_skills = search_skills(user_input)
        if len(matched_skills) > 0 {
            print("📚 Found " + str(len(matched_skills)) + " matching skill(s)\n")
        }

        // 3. LLM reasoning with full context
        // The LLM can now call any function defined in the `functions` block
        llm stream
    }
}

