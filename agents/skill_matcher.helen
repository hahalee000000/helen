// ============================================================
// Skill Matcher Agent
// Searches and matches skills based on context (error messages,
// code snippets, questions).
//
// Uses SKILL_INDEX.md for fast keyword-based matching.
// ============================================================

// ── Helper Functions ─────────────────────────────────────────

fn get_index_path() -> str {
    // Returns path to the skill index file
    return "agents/skills/SKILL_INDEX.md"
}

fn load_index() -> str {
    // Loads the skill index content
    let path = get_index_path()
    if path_exists(path) {
        return read_file(path)
    }
    return ""
}

fn extract_keywords_from_error(context: str) -> list {
    // Extracts searchable keywords from error context
    let keywords = []
    
    // Division-related
    if regex_search(context, "(?i)division") {
        keywords.append("division")
    }
    if regex_search(context, "(?i)divide") {
        keywords.append("division")
    }
    if regex_search(context, "(?i)zero") {
        keywords.append("zero")
    }
    
    // Index-related
    if regex_search(context, "(?i)index") {
        keywords.append("index")
    }
    if regex_search(context, "(?i)range") {
        keywords.append("range")
    }
    if regex_search(context, "(?i)out of bounds") {
        keywords.append("index")
    }
    
    // Null-related
    if regex_search(context, "(?i)null") {
        keywords.append("null")
    }
    if regex_search(context, "(?i)none") {
        keywords.append("null")
    }
    if regex_search(context, "(?i)undefined") {
        keywords.append("null")
    }
    
    // Quality-related
    if regex_search(context, "(?i)complexity") {
        keywords.append("complexity")
    }
    if regex_search(context, "(?i)security") {
        keywords.append("security")
    }
    if regex_search(context, "(?i)quality") {
        keywords.append("quality")
    }
    if regex_search(context, "(?i)coverage") {
        keywords.append("coverage")
    }
    
    // Testing-related
    if regex_search(context, "(?i)test") {
        keywords.append("test")
    }
    if regex_search(context, "(?i)assert") {
        keywords.append("test")
    }
    
    // Architecture-related
    if regex_search(context, "(?i)architecture") {
        keywords.append("architecture")
    }
    if regex_search(context, "(?i)design") {
        keywords.append("architecture")
    }
    if regex_search(context, "(?i)pattern") {
        keywords.append("architecture")
    }
    
    return keywords
}

fn search_index_for_keyword(index: str, keyword: str) -> bool {
    // Checks if keyword appears in the index
    return regex_search(index, "(?i)" + keyword)
}

fn find_matching_skills(keywords: list, index: str) -> list {
    // Finds all skills that match any of the keywords
    let matches = []
    
    for keyword in keywords {
        if search_index_for_keyword(index, keyword) {
            matches.append(keyword)
        }
    }
    
    return matches
}

fn get_skill_names_from_index(index: str) -> list {
    // Extracts skill names from index (lines starting with ###)
    let lines = split(index, "\n")
    let names = []
    
    for line in lines {
        let trimmed = strip(line)
        if startswith(trimmed, "### ") {
            let name = substring(trimmed, 4)
            names.append(name)
        }
    }
    
    return names
}

// ── Skill Matcher Agent ──────────────────────────────────────

agent SkillMatcher(context: str) {
    description "Search and match skills based on context"
    model "gpt-4"
    temperature 0.1

    prompt """
    You are the Skill Matcher for Helen Programming Agent.
    
    Context: {{context}}
    
    Your job:
    1. Extract keywords from the context
    2. Search SKILL_INDEX.md for matching skills
    3. Return matched skills with confidence scores
    
    Return a map with:
    - matches: list of matched skill info
    - keywords: extracted keywords
    - count: number of matches
    """

    functions {
        fn do_match(context: str) -> map {
            // Load index
            let index = load_index()
            if len(index) == 0 {
                return {
                    "matches": [],
                    "keywords": [],
                    "count": 0,
                    "message": "No skill index found"
                }
            }
            
            // Extract keywords
            let keywords = extract_keywords_from_error(context)
            
            // Find matches
            let matched_keywords = find_matching_skills(keywords, index)
            
            // Get all skill names
            let all_skills = get_skill_names_from_index(index)
            
            // Filter skills that match keywords
            let matched_skills = []
            for skill_name in all_skills {
                for kw in matched_keywords {
                    if regex_search(skill_name, "(?i)" + kw) {
                        matched_skills.append(skill_name)
                    }
                }
            }
            
            return {
                "matches": matched_skills,
                "keywords": keywords,
                "matched_keywords": matched_keywords,
                "count": len(matched_skills),
                "message": "Found " + str(len(matched_skills)) + " matching skills"
            }
        }
    }

    main {
        let result = do_match(context)
        return result
    }
}
