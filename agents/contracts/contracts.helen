// Helen Programming Agent v5.2 - 契约定义

// ─── 错误码 ───

const ERR_AGENT_FAILED = 5001
const ERR_CONTRACT_INVALID = 5002
const ERR_TEST_GENERATION_FAILED = 5003
const ERR_IMPLEMENTATION_FAILED = 5004
const ERR_QUALITY_BELOW_THRESHOLD = 5005
const ERR_SKILL_EVALUATION_FAILED = 5006
const ERR_FILE_NOT_FOUND = 5007
const ERR_PATCH_FAILED = 5008

// ─── 质量阈值 ───

const QUALITY_THRESHOLD = 7.5
const MIN_DIMENSION_SCORE = 6.0

// ─── Agent 接口契约 ───

// Contractor: 设计接口和契约
// 输入: requirement (str), context (str)
// 输出: map { "contract": str, "modules": list, "status": str }
protocol ContractorContract {
    fn design_contract(requirement: str, context: str): map
}

// TestBuilder: 生成测试
// 输入: source_code (str), contract (str)
// 输出: map { "test_code": str, "test_count": int, "status": str }
protocol TestBuilderContract {
    fn generate_tests(source_code: str, contract: str): map
}

// Implementer: 实现代码（TDD循环）
// 输入: source_code (str), test_code (str), contract (str)
// 输出: map { "implementation": str, "tests_passed": bool, "iterations": int, "status": str }
protocol ImplementerContract {
    fn implement_code(source_code: str, test_code: str, contract: str): map
}

// QualityGate: 质量评估
// 输入: file_path (str), before_scores (str)
// 输出: map { "scores": map, "verdict": str, "report": str }
protocol QualityGateContract {
    fn evaluate_quality(file_path: str, before_scores: str): map
}

// SkillEvaluator: 技能自进化
// 输入: task_summary (str), files_changed (str)
// 输出: map { "new_skills": list, "updates": list, "status": str }
protocol SkillEvaluatorContract {
    fn evaluate_skills(task_summary: str, files_changed: str): map
}

// HelenProgrammer: 主编排
// 输入: requirement (str), project_dir (str)
// 输出: map { "status": str, "phases": map }
protocol HelenProgrammerContract {
    fn orchestrate_workflow(requirement: str, project_dir: str): map
}
