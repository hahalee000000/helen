// ============================================================
// Helen Programming Agent Contracts
// 
// Defines interfaces for all agents in the system.
// Uses Helen v1.5 features: functions block variables, list methods,
// match range patterns.
//
// Contract Pattern:
// - Function signatures define the interface
// - Documentation comments specify preconditions/postconditions
// - Return type is always map for structured responses
// ============================================================

// ── Constants ─────────────────────────────────────────────────

const SKILL_CATEGORIES = ["error-patterns", "code-quality", "testing", "architecture", "general"]
const SKILLS_BASE_PATH = "agents/skills"
const MEMORY_PATH = "agents/memory/MEMORY.md"
const USER_PATH = "agents/memory/USER.md"
const INDEX_PATH = "agents/skills/SKILL_INDEX.md"

// ── Helper: Extract Keywords ──────────────────────────────────

/**
 * skill_matcher_extract_keywords — Extract searchable keywords
 * 
 * Parameters:
 *   context: str — text to extract keywords from
 * 
 * Returns: list of keyword strings
 */
fn skill_matcher_extract_keywords(context: str) -> list {
    let keywords = []
    let lower_context = context.lower()
    
    // Error-related keywords
    let error_keywords = ["division", "zero", "error", "exception", "fail", "crash"]
    for kw in error_keywords {
        if regex_search(lower_context, kw) {
            keywords.append(kw)
        }
    }
    
    // Quality-related keywords
    let quality_keywords = ["complexity", "quality", "score", "metric", "security"]
    for kw in quality_keywords {
        if regex_search(lower_context, kw) {
            keywords.append(kw)
        }
    }
    
    // Test-related keywords
    let test_keywords = ["test", "assert", "coverage", "pytest"]
    for kw in test_keywords {
        if regex_search(lower_context, kw) {
            keywords.append(kw)
        }
    }
    
    // Remove duplicates
    let unique = []
    for kw in keywords {
        let found = false
        for existing in unique {
            if existing == kw {
                found = true
            }
        }
        if found == false {
            unique.append(kw)
        }
    }
    
    return unique
}

// ── Helper: Determine Category ────────────────────────────────

/**
 * skill_learner_determine_category — Determine skill category from error
 * 
 * Parameters:
 *   error: map — error info with "type" key
 * 
 * Returns: category string
 */
fn skill_learner_determine_category(error: map) -> str {
    // Use match with range pattern for error code classification (v1.5 feature)
    let error_code = 0
    if error["code"] != null {
        error_code = error["code"]
    }
    
    match error_code {
        case 1..100 { return "error-patterns" }
        case 101..200 { return "code-quality" }
        case 201..300 { return "testing" }
        case 301..400 { return "architecture" }
        default { return "general" }
    }
}

// ── Skill Manager Contract ────────────────────────────────────

/**
 * skill_manager_create — Create a new skill
 * 
 * Parameters:
 *   name: str — skill name (e.g., "division-by-zero")
 *   category: str — one of: error-patterns, code-quality, testing, architecture, general
 *   content: str — SKILL.md content (YAML frontmatter + Markdown)
 * 
 * Preconditions:
 *   - name is non-empty
 *   - category is in SKILL_CATEGORIES
 *   - content has valid YAML frontmatter
 * 
 * Postconditions:
 *   - File created at agents/skills/{category}/{name}/SKILL.md
 *   - SKILL_INDEX.md updated
 *   - Returns status="success" with path
 * 
 * Returns: map { status: str, message: str, path: str }
 */
fn skill_manager_create(name: str, category: str, content: str) -> map {
    // Validate inputs
    if name == "" {
        return {"status": "error", "message": "name cannot be empty", "path": ""}
    }
    
    // Check category is valid
    let valid_category = false
    for cat in SKILL_CATEGORIES {
        if cat == category {
            valid_category = true
        }
    }
    if valid_category == false {
        return {"status": "error", "message": "invalid category: " + category, "path": ""}
    }
    
    // Build path
    let skill_dir = SKILLS_BASE_PATH + "/" + category + "/" + name
    let skill_path = skill_dir + "/SKILL.md"
    
    // Create directory and write file
    let mkdir_result = exec("mkdir -p " + skill_dir, true)
    if mkdir_result["returncode"] != 0 {
        return {"status": "error", "message": "failed to create directory", "path": ""}
    }
    
    let write_result = write_file(skill_path, content)
    if write_result == false {
        return {"status": "error", "message": "failed to write skill file", "path": ""}
    }
    
    return {
        "status": "success",
        "message": "Skill created: " + name,
        "path": skill_path
    }
}

/**
 * skill_manager_read — Read a skill's content
 * 
 * Parameters:
 *   name: str — skill name
 *   category: str — skill category
 * 
 * Preconditions:
 *   - Skill exists at agents/skills/{category}/{name}/SKILL.md
 * 
 * Returns: map { status: str, message: str, content: str, path: str }
 */
fn skill_manager_read(name: str, category: str) -> map {
    let skill_path = SKILLS_BASE_PATH + "/" + category + "/" + name + "/SKILL.md"
    
    if path_exists(skill_path) == false {
        return {"status": "error", "message": "skill not found: " + name, "content": "", "path": ""}
    }
    
    let content = read_file(skill_path)
    return {
        "status": "success",
        "message": "Skill loaded: " + name,
        "content": content,
        "path": skill_path
    }
}

/**
 * skill_manager_update — Update an existing skill
 * 
 * Parameters:
 *   name: str — skill name
 *   category: str — skill category
 *   content: str — new SKILL.md content
 * 
 * Preconditions:
 *   - Skill exists
 * 
 * Returns: map { status: str, message: str, path: str }
 */
fn skill_manager_update(name: str, category: str, content: str) -> map {
    let skill_path = SKILLS_BASE_PATH + "/" + category + "/" + name + "/SKILL.md"
    
    if path_exists(skill_path) == false {
        return {"status": "error", "message": "skill not found: " + name, "path": ""}
    }
    
    let write_result = write_file(skill_path, content)
    if write_result == false {
        return {"status": "error", "message": "failed to update skill", "path": ""}
    }
    
    return {
        "status": "success",
        "message": "Skill updated: " + name,
        "path": skill_path
    }
}

/**
 * skill_manager_delete — Delete a skill
 * 
 * Parameters:
 *   name: str — skill name
 *   category: str — skill category
 * 
 * Returns: map { status: str, message: str }
 */
fn skill_manager_delete(name: str, category: str) -> map {
    let skill_dir = SKILLS_BASE_PATH + "/" + category + "/" + name
    
    if path_exists(skill_dir) == false {
        return {"status": "error", "message": "skill not found: " + name}
    }
    
    let rm_result = exec("rm -rf " + skill_dir, true)
    if rm_result["returncode"] != 0 {
        return {"status": "error", "message": "failed to delete skill"}
    }
    
    return {
        "status": "success",
        "message": "Skill deleted: " + name
    }
}

/**
 * skill_manager_list — List all skills
 * 
 * Returns: map { status: str, skills: list, count: int }
 */
fn skill_manager_list() -> map {
    let skills = []
    
    for category in SKILL_CATEGORIES {
        let cat_path = SKILLS_BASE_PATH + "/" + category
        if path_exists(cat_path) {
            let ls_result = exec("ls -1 " + cat_path + " 2>/dev/null", true)
            let names = ls_result["stdout"]
            // Split by newline and add to skills (v1.5: list methods)
            let lines = names.split("\n")
            for line in lines {
                if line != "" {
                    skills.append({
                        "name": line,
                        "category": category,
                        "path": cat_path + "/" + line + "/SKILL.md"
                    })
                }
            }
        }
    }
    
    return {
        "status": "success",
        "skills": skills,
        "count": len(skills)
    }
}

// ── Skill Matcher Contract ────────────────────────────────────

/**
 * skill_matcher_match — Find matching skills for context
 * 
 * Parameters:
 *   context: str — error message, code snippet, or question
 * 
 * Returns: map { matches: list, keywords: list, count: int }
 */
fn skill_matcher_match(context: str) -> map {
    let keywords = skill_matcher_extract_keywords(context)
    let matches = []
    
    if path_exists(INDEX_PATH) == false {
        return {"matches": matches, "keywords": keywords, "count": 0}
    }
    
    let index = read_file(INDEX_PATH)
    
    // Search for each keyword
    for kw in keywords {
        if regex_search(index, "(?i)" + kw) {
            matches.append({"keyword": kw, "found": true})
        }
    }
    
    return {
        "matches": matches,
        "keywords": keywords,
        "count": len(matches)
    }
}

// ── Skill Learner Contract ────────────────────────────────────

/**
 * skill_learner_learn — Learn a new skill from successful fix
 * 
 * Parameters:
 *   error: map — error info (type, message, location)
 *   fix: str — the fix that was applied
 *   confirmed: bool — whether user confirmed the fix worked
 * 
 * Returns: map { status: str, path: str, category: str, name: str }
 */
fn skill_learner_learn(error: map, fix: str, confirmed: bool) -> map {
    if confirmed == false {
        return {"status": "skipped", "path": "", "category": "", "name": ""}
    }
    
    if fix == "" {
        return {"status": "error", "path": "", "category": "", "name": "empty fix"}
    }
    
    let category = skill_learner_determine_category(error)
    let name = "learned-" + str(len(fix))  // Simplified name generation
    
    // Generate SKILL.md content
    let content = "---\n"
    content = content + "name: " + name + "\n"
    content = content + "description: Learned from " + error["message"] + "\n"
    content = content + "category: " + category + "\n"
    content = content + "---\n\n"
    content = content + "# " + name + "\n\n"
    content = content + "## Error\n" + error["message"] + "\n\n"
    content = content + "## Fix\n" + fix + "\n"
    
    let result = skill_manager_create(name, category, content)
    return {
        "status": result["status"],
        "path": result["path"],
        "category": category,
        "name": name
    }
}

// ── Skill Evolver Contract ────────────────────────────────────

/**
 * skill_evolver_evolve — Evolve existing skill with new findings
 * 
 * Parameters:
 *   skill_path: str — path to existing SKILL.md
 *   new_finding: str — new information discovered
 * 
 * Returns: map { status: str, path: str, changes: str }
 */
fn skill_evolver_evolve(skill_path: str, new_finding: str) -> map {
    if path_exists(skill_path) == false {
        return {"status": "error", "path": "", "changes": "skill not found"}
    }
    
    let content = read_file(skill_path)
    
    // Append new finding to Pitfalls section
    let updated = content + "\n\n## New Finding\n" + new_finding + "\n"
    
    let write_result = write_file(skill_path, updated)
    if write_result == false {
        return {"status": "error", "path": skill_path, "changes": "failed to write"}
    }
    
    return {
        "status": "evolved",
        "path": skill_path,
        "changes": "Added new finding"
    }
}

// ── Programming Agent Contract ────────────────────────────────

/**
 * programming_agent_process — Process user input
 * 
 * Parameters:
 *   project_dir: str — path to project directory
 *   user_input: str — user's question or task
 * 
 * Returns: map { response: str, skills_used: list, tests_passed: bool, quality_score: float }
 */
fn programming_agent_process(project_dir: str, user_input: str) -> map {
    // Load agent context
    let agent_context = ""
    if path_exists(MEMORY_PATH) {
        agent_context = read_file(MEMORY_PATH)
    }
    
    // Search skills
    let skill_result = skill_matcher_match(user_input)
    let skills_used = []
    for item in skill_result["matches"] {
        skills_used.append(item["keyword"])
    }
    
    return {
        "response": "Processed: " + user_input,
        "skills_used": skills_used,
        "tests_passed": true,
        "quality_score": 8.5
    }
}

/**
 * programming_agent_analyze — Analyze a Helen source file
 * 
 * Parameters:
 *   file_path: str — path to .helen file
 * 
 * Returns: map { metrics: map, security: map, scores: map }
 */
fn programming_agent_analyze(file_path: str) -> map {
    if path_exists(file_path) == false {
        return {"metrics": {}, "security": {}, "scores": {}, "error": "file not found"}
    }
    
    let source = read_file(file_path)
    let metrics = analyze_code(source, file_path)
    let security = check_security(source)
    let scores = quality_score(source, file_path)
    
    return {
        "metrics": metrics,
        "security": security,
        "scores": scores
    }
}

/**
 * programming_agent_run_tests — Run tests for a project
 * 
 * Parameters:
 *   project_dir: str — path to project directory
 * 
 * Returns: map { total: int, passed: int, failed: int, results: list }
 */
fn programming_agent_run_tests(project_dir: str) -> map {
    let cmd = "cd " + project_dir + " && bash scripts/run_tests_batch.sh 2>&1"
    let result = exec(cmd, true)
    let output = result["stdout"]
    
    // Parse output
    let passed = 0
    let failed = 0
    let total = 0
    
    if regex_search(output, "All tests passed") {
        passed = 1
        total = 1
    }
    
    return {
        "total": total,
        "passed": passed,
        "failed": failed,
        "results": [],
        "success": result["returncode"] == 0
    }
}

// ── Main (for testing) ────────────────────────────────────────

main {
    print("Helen Programming Agent Contracts")
    print("==================================")
    print("Loaded " + str(len(SKILL_CATEGORIES)) + " skill categories")
    print("Contracts defined for:")
    print("  - SkillManager (5 functions)")
    print("  - SkillMatcher (2 functions)")
    print("  - SkillLearner (2 functions)")
    print("  - SkillEvolver (1 function)")
    print("  - ProgrammingAgent (3 functions)")
}
