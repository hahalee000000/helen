// Helen Programming Agent - Contracts
// 定义所有 Agent 的协议接口、错误码和辅助函数

// ─── 错误码定义 ───

const ERR_AGENT_FAILED = 5001
const ERR_CONTRACT_INVALID = 5002
const ERR_TEST_GENERATION_FAILED = 5003
const ERR_IMPLEMENTATION_FAILED = 5004
const ERR_QUALITY_BELOW_THRESHOLD = 5005
const ERR_SKILL_EVALUATION_FAILED = 5006
const ERR_FILE_NOT_FOUND = 5007
const ERR_PATCH_FAILED = 5008

// ─── 质量阈值 ───

const QUALITY_THRESHOLD = 7.5
const MIN_DIMENSION_SCORE = 6.0

// ─── Protocol 定义 ───

protocol ContractorOutput {
    fn design_contract(requirement: str, context: str): map
}

protocol TestBuilderOutput {
    fn generate_tests(source_code: str, contract: str): map
}

protocol ImplementerOutput {
    fn implement_code(source_code: str, test_code: str, contract: str): map
}

protocol QualityGateOutput {
    fn evaluate_quality(file_path: str, before_scores: str): map
}

protocol SkillEvaluatorOutput {
    fn evaluate_skills(task_summary: str, files_changed: str): map
}

protocol ProgrammingAgentOutput {
    fn orchestrate_workflow(requirement: str, project_dir: str): map
}

// ─── 辅助函数 ───

fn is_quality_pass(scores: map): bool {
    let total = 0.0
    let dimensions = ["security", "correctness", "maintainability", "performance", "testability", "helen_conventions", "documentation"]
    
    for dim in dimensions {
        let score = scores[dim]
        if score == null {
            return false
        }
        if score < MIN_DIMENSION_SCORE {
            return false
        }
        total = total + score
    }
    
    let avg = total / 7.0
    return avg >= QUALITY_THRESHOLD
}

fn format_quality_report(before: map, after: map): str {
    let report = "## 质量评估报告\n\n"
    report = report + "| 维度 | 修改前 | 修改后 | 变化 |\n"
    report = report + "|------|--------|--------|------|\n"
    
    let dimensions = ["security", "correctness", "maintainability", "performance", "testability", "helen_conventions", "documentation"]
    
    for dim in dimensions {
        let before_score = before[dim]
        let after_score = after[dim]
        let delta = after_score - before_score
        
        let arrow = "→"
        if delta > 0 {
            arrow = "↑"
        } else if delta < 0 {
            arrow = "↓"
        }
        
        report = report + "| " + dim + " | " + str(before_score) + " | " + str(after_score) + " | " + arrow + " " + str(delta) + " |\n"
    }
    
    report = report + "\n"
    return report
}

fn extract_error_code(result: map): int {
    if result["error_code"] != null {
        return result["error_code"]
    }
    return 0
}

fn is_success(result: map): bool {
    return result["status"] == "success"
}
