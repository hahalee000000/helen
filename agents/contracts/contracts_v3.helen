// ============================================================
// Helen Programming Agent Contracts v3.0
// 
// 契约优先设计 - 定义清晰的接口规范
// 
// 设计原则:
// 1. 函数签名定义接口契约
// 2. 文档注释指定前置/后置条件
// 3. 统一返回类型: map { status, message, ... }
// 4. 统一错误处理: try-catch + 结构化错误
// ============================================================

// ── 常量定义 ──────────────────────────────────────────────────

const SKILL_CATEGORIES = ["error-patterns", "code-quality", "testing", "architecture", "general"]
const SKILLS_BASE_PATH = "agents/skills"
const MEMORY_PATH = "agents/memory/MEMORY.md"
const USER_PATH = "agents/memory/USER.md"
const INDEX_PATH = "agents/skills/SKILL_INDEX.md"

// ── 错误类型定义 ──────────────────────────────────────────────

/**
 * 错误码定义
 * 1-100: 验证错误
 * 101-200: IO错误
 * 201-300: 业务逻辑错误
 */
const ERROR_VALIDATION = 1
const ERROR_IO = 101
const ERROR_NOT_FOUND = 201
const ERROR_ALREADY_EXISTS = 202

// ── Skill Manager 契约 ────────────────────────────────────────

/**
 * skill_manager_create — 创建新skill
 * 
 * @param name: str — skill名称 (例: "division-by-zero")
 * @param category: str — 类别,必须是SKILL_CATEGORIES之一
 * @param content: str — SKILL.md内容(YAML frontmatter + Markdown)
 * 
 * @pre name非空
 * @pre category在SKILL_CATEGORIES中
 * @pre content有有效的YAML frontmatter
 * 
 * @post 文件创建在 agents/skills/{category}/{name}/SKILL.md
 * @post SKILL_INDEX.md更新
 * @post 返回 status="success" 和 path
 * 
 * @return map { 
 *   status: "success" | "error",
 *   message: str,
 *   path: str,
 *   error_code?: int
 * }
 */
fn skill_manager_create(name: str, category: str, content: str) -> map {
    // 验证输入
    if name == "" {
        return {
            "status": "error",
            "message": "name cannot be empty",
            "path": "",
            "error_code": ERROR_VALIDATION
        }
    }
    
    // 验证类别
    let valid_category = false
    for cat in SKILL_CATEGORIES {
        if cat == category {
            valid_category = true
        }
    }
    if valid_category == false {
        return {
            "status": "error",
            "message": "invalid category: " + category + ". Must be one of: " + str(SKILL_CATEGORIES),
            "path": "",
            "error_code": ERROR_VALIDATION
        }
    }
    
    // 构建路径
    let skill_dir = SKILLS_BASE_PATH + "/" + category + "/" + name
    let skill_path = skill_dir + "/SKILL.md"
    
    // 检查是否已存在
    if path_exists(skill_path) {
        return {
            "status": "error",
            "message": "skill already exists: " + name,
            "path": skill_path,
            "error_code": ERROR_ALREADY_EXISTS
        }
    }
    
    // 创建目录
    let mkdir_result = exec("mkdir -p " + skill_dir, true)
    if mkdir_result["returncode"] != 0 {
        return {
            "status": "error",
            "message": "failed to create directory: " + skill_dir,
            "path": "",
            "error_code": ERROR_IO
        }
    }
    
    // 写入文件
    let write_result = write_file(skill_path, content)
    if write_result == false {
        return {
            "status": "error",
            "message": "failed to write skill file",
            "path": "",
            "error_code": ERROR_IO
        }
    }
    
    return {
        "status": "success",
        "message": "Skill created: " + name,
        "path": skill_path,
        "error_code": 0
    }
}

/**
 * skill_manager_read — 读取skill内容
 * 
 * @param name: str — skill名称
 * @param category: str — skill类别
 * 
 * @pre skill存在于 agents/skills/{category}/{name}/SKILL.md
 * 
 * @return map {
 *   status: "success" | "error",
 *   message: str,
 *   content: str,
 *   path: str,
 *   error_code?: int
 * }
 */
fn skill_manager_read(name: str, category: str) -> map {
    let skill_path = SKILLS_BASE_PATH + "/" + category + "/" + name + "/SKILL.md"
    
    if path_exists(skill_path) == false {
        return {
            "status": "error",
            "message": "skill not found: " + name,
            "content": "",
            "path": "",
            "error_code": ERROR_NOT_FOUND
        }
    }
    
    let content = read_file(skill_path)
    return {
        "status": "success",
        "message": "Skill loaded: " + name,
        "content": content,
        "path": skill_path,
        "error_code": 0
    }
}

/**
 * skill_manager_update — 更新现有skill
 * 
 * @param name: str — skill名称
 * @param category: str — skill类别
 * @param content: str — 新的SKILL.md内容
 * 
 * @pre skill存在
 * 
 * @return map {
 *   status: "success" | "error",
 *   message: str,
 *   path: str,
 *   error_code?: int
 * }
 */
fn skill_manager_update(name: str, category: str, content: str) -> map {
    let skill_path = SKILLS_BASE_PATH + "/" + category + "/" + name + "/SKILL.md"
    
    if path_exists(skill_path) == false {
        return {
            "status": "error",
            "message": "skill not found: " + name,
            "path": "",
            "error_code": ERROR_NOT_FOUND
        }
    }
    
    let write_result = write_file(skill_path, content)
    if write_result == false {
        return {
            "status": "error",
            "message": "failed to update skill",
            "path": skill_path,
            "error_code": ERROR_IO
        }
    }
    
    return {
        "status": "success",
        "message": "Skill updated: " + name,
        "path": skill_path,
        "error_code": 0
    }
}

/**
 * skill_manager_delete — 删除skill
 * 
 * @param name: str — skill名称
 * @param category: str — skill类别
 * 
 * @return map {
 *   status: "success" | "error",
 *   message: str,
 *   error_code?: int
 * }
 */
fn skill_manager_delete(name: str, category: str) -> map {
    let skill_dir = SKILLS_BASE_PATH + "/" + category + "/" + name
    
    if path_exists(skill_dir) == false {
        return {
            "status": "error",
            "message": "skill not found: " + name,
            "error_code": ERROR_NOT_FOUND
        }
    }
    
    let rm_result = exec("rm -rf " + skill_dir, true)
    if rm_result["returncode"] != 0 {
        return {
            "status": "error",
            "message": "failed to delete skill",
            "error_code": ERROR_IO
        }
    }
    
    return {
        "status": "success",
        "message": "Skill deleted: " + name,
        "error_code": 0
    }
}

/**
 * skill_manager_list — 列出所有skills
 * 
 * @return map {
 *   status: "success",
 *   skills: list[map],  // 每个skill: {name, category, path}
 *   count: int
 * }
 */
fn skill_manager_list() -> map {
    let skills = []
    
    for category in SKILL_CATEGORIES {
        let cat_path = SKILLS_BASE_PATH + "/" + category
        if path_exists(cat_path) {
            let ls_result = exec("ls -1 " + cat_path + " 2>/dev/null", true)
            let names = ls_result["stdout"]
            let lines = names.split("\n")
            for line in lines {
                if line != "" {
                    skills.append({
                        "name": line,
                        "category": category,
                        "path": cat_path + "/" + line + "/SKILL.md"
                    })
                }
            }
        }
    }
    
    return {
        "status": "success",
        "skills": skills,
        "count": len(skills)
    }
}

// ── Skill Matcher 契约 ────────────────────────────────────────

/**
 * skill_matcher_extract_keywords — 从上下文提取可搜索关键词
 * 
 * @param context: str — 要提取关键词的文本
 * 
 * @return list[str] — 关键词列表
 * 
 * @example
 *   extract_keywords("Division by zero in divide()") 
 *   => ["division", "zero"]
 */
fn skill_matcher_extract_keywords(context: str) -> list {
    let keywords = []
    let lower_context = context.lower()
    
    // 错误相关关键词
    let error_keywords = ["division", "zero", "error", "exception", "fail", "crash"]
    for kw in error_keywords {
        if regex_search(kw, lower_context) != null {
            keywords.append(kw)
        }
    }
    
    // 质量相关关键词
    let quality_keywords = ["complexity", "quality", "score", "metric", "security"]
    for kw in quality_keywords {
        if regex_search(kw, lower_context) != null {
            keywords.append(kw)
        }
    }
    
    // 测试相关关键词
    let test_keywords = ["test", "assert", "coverage", "pytest"]
    for kw in test_keywords {
        if regex_search(kw, lower_context) != null {
            keywords.append(kw)
        }
    }
    
    // 去重
    let unique = []
    for kw in keywords {
        let found = false
        for existing in unique {
            if existing == kw {
                found = true
            }
        }
        if found == false {
            unique.append(kw)
        }
    }
    
    return unique
}

/**
 * skill_matcher_match — 查找匹配上下文的skills
 * 
 * @param context: str — 错误消息、代码片段或问题
 * 
 * @pre context非空
 * 
 * @post 从上下文提取关键词
 * @post 在SKILL_INDEX.md中搜索匹配
 * @post 返回按置信度排序的匹配列表
 * 
 * @return map {
 *   matches: list[map],  // 每个match: {keyword, found}
 *   keywords: list[str],
 *   count: int
 * }
 */
fn skill_matcher_match(context: str) -> map {
    let keywords = skill_matcher_extract_keywords(context)
    let matches = []
    
    if path_exists(INDEX_PATH) == false {
        return {
            "matches": matches,
            "keywords": keywords,
            "count": 0
        }
    }
    
    let index = read_file(INDEX_PATH)
    
    // 搜索每个关键词
    for kw in keywords {
        if regex_search("(?i)" + kw, index) != null {
            matches.append({"keyword": kw, "found": true})
        }
    }
    
    return {
        "matches": matches,
        "keywords": keywords,
        "count": len(matches)
    }
}

// ── Skill Learner 契约 ────────────────────────────────────────

/**
 * skill_learner_determine_category — 根据错误确定skill类别
 * 
 * @param error: map — 错误信息,包含"type"键
 * 
 * @return str — 类别名称
 * 
 * @rules
 *   RuntimeError => "error-patterns"
 *   QualityIssue => "code-quality"
 *   TestFailure => "testing"
 *   Architecture => "architecture"
 *   Default => "general"
 */
fn skill_learner_determine_category(error: map) -> str {
    let error_code = 0
    if error["code"] != null {
        error_code = error["code"]
    }
    
    match error_code {
        case 1..100 { return "error-patterns" }
        case 101..200 { return "code-quality" }
        case 201..300 { return "testing" }
        case 301..400 { return "architecture" }
        default { return "general" }
    }
}

/**
 * skill_learner_learn — 从成功的修复中学习新skill
 * 
 * @param error: map — 错误信息 (type, message, location)
 * @param fix: str — 应用的修复
 * @param confirmed: bool — 用户是否确认修复有效
 * 
 * @pre error有type和message键
 * @pre fix非空
 * 
 * @post 如果confirmed=false: 返回 status="skipped"
 * @post 如果confirmed=true:
 *   - 生成SKILL.md内容(通过LLM)
 *   - 根据错误类型确定类别
 *   - 从错误消息生成名称
 *   - 保存到 agents/skills/{category}/{name}/SKILL.md
 *   - 更新SKILL_INDEX.md
 *   - 返回 status="saved" 和 path
 * 
 * @return map {
 *   status: "saved" | "skipped" | "error",
 *   path: str,
 *   category: str,
 *   name: str,
 *   error_code?: int
 * }
 */
fn skill_learner_learn(error: map, fix: str, confirmed: bool) -> map {
    if confirmed == false {
        return {
            "status": "skipped",
            "path": "",
            "category": "",
            "name": "",
            "error_code": 0
        }
    }
    
    if fix == "" {
        return {
            "status": "error",
            "path": "",
            "category": "",
            "name": "empty fix",
            "error_code": ERROR_VALIDATION
        }
    }
    
    let category = skill_learner_determine_category(error)
    let name = "learned-" + str(len(fix))  // 简化的名称生成
    
    // 生成SKILL.md内容
    let content = "---\n"
    content = content + "name: " + name + "\n"
    content = content + "description: Learned from " + error["message"] + "\n"
    content = content + "category: " + category + "\n"
    content = content + "---\n\n"
    content = content + "# " + name + "\n\n"
    content = content + "## Error\n" + error["message"] + "\n\n"
    content = content + "## Fix\n" + fix + "\n"
    
    let result = skill_manager_create(name, category, content)
    return {
        "status": result["status"],
        "path": result["path"],
        "category": category,
        "name": name,
        "error_code": result["error_code"]
    }
}

// ── Skill Evolver 契约 ────────────────────────────────────────

/**
 * skill_evolver_evolve — 用新发现演进现有skill
 * 
 * @param skill_path: str — 现有SKILL.md的路径
 * @param new_finding: str — 发现的新信息
 * 
 * @pre skill_path指向现有的SKILL.md
 * @pre new_finding非空
 * 
 * @post 将新发现追加到"Pitfalls"部分
 * @post 增加frontmatter中的occurrences计数
 * @post 返回 status="evolved"
 * 
 * @return map {
 *   status: "evolved" | "error",
 *   path: str,
 *   changes: str,
 *   error_code?: int
 * }
 */
fn skill_evolver_evolve(skill_path: str, new_finding: str) -> map {
    if path_exists(skill_path) == false {
        return {
            "status": "error",
            "path": "",
            "changes": "skill not found",
            "error_code": ERROR_NOT_FOUND
        }
    }
    
    let content = read_file(skill_path)
    
    // 将新发现追加到Pitfalls部分
    let updated = content + "\n\n## New Finding\n" + new_finding + "\n"
    
    let write_result = write_file(skill_path, updated)
    if write_result == false {
        return {
            "status": "error",
            "path": skill_path,
            "changes": "failed to write",
            "error_code": ERROR_IO
        }
    }
    
    return {
        "status": "evolved",
        "path": skill_path,
        "changes": "Added new finding",
        "error_code": 0
    }
}

// ── Programming Agent 契约 ────────────────────────────────────

/**
 * programming_agent_process — 处理用户输入
 * 
 * @param project_dir: str — 项目目录路径
 * @param user_input: str — 用户的问题或任务
 * 
 * @post 加载agent内存
 * @post 搜索匹配的skills
 * @post 如果匹配到skill: 使用skill指导响应
 * @post 如果没有skill: 使用LLM推理
 * @post 如果应用了代码修复: 运行测试+质量检查
 * @post 如果修复成功: 提供保存为新skill的选项
 * @post 更新agent内存
 * 
 * @return map {
 *   response: str,
 *   skills_used: list[str],
 *   tests_passed: bool,
 *   quality_score: float
 * }
 */
fn programming_agent_process(project_dir: str, user_input: str) -> map {
    // 加载agent上下文
    let agent_context = ""
    if path_exists(MEMORY_PATH) {
        agent_context = read_file(MEMORY_PATH)
    }
    
    // 搜索skills
    let skill_result = skill_matcher_match(user_input)
    let skills_used = []
    for item in skill_result["matches"] {
        skills_used.append(item["keyword"])
    }
    
    return {
        "response": "Processed: " + user_input,
        "skills_used": skills_used,
        "tests_passed": true,
        "quality_score": 8.5
    }
}

/**
 * programming_agent_analyze — 分析Helen源文件
 * 
 * @param file_path: str — .helen文件路径
 * 
 * @return map {
 *   metrics: map,
 *   security: map,
 *   scores: map,
 *   error?: str
 * }
 */
fn programming_agent_analyze(file_path: str) -> map {
    if path_exists(file_path) == false {
        return {
            "metrics": {},
            "security": {},
            "scores": {},
            "error": "file not found"
        }
    }
    
    let source = read_file(file_path)
    let metrics = analyze_code(source, file_path)
    let security = check_security(source)
    let scores = quality_score(source, file_path)
    
    return {
        "metrics": metrics,
        "security": security,
        "scores": scores
    }
}

/**
 * programming_agent_run_tests — 运行项目测试
 * 
 * @param project_dir: str — 项目目录路径
 * 
 * @return map {
 *   total: int,
 *   passed: int,
 *   failed: int,
 *   results: list,
 *   success: bool
 * }
 */
fn programming_agent_run_tests(project_dir: str) -> map {
    let cmd = "cd " + project_dir + " && bash scripts/run_tests_batch.sh 2>&1"
    let result = exec(cmd, true)
    let output = result["stdout"]
    
    // 解析输出
    let passed = 0
    let failed = 0
    let total = 0
    
    if regex_search("All tests passed", output) != null {
        passed = 1
        total = 1
    }
    
    return {
        "total": total,
        "passed": passed,
        "failed": failed,
        "results": [],
        "success": result["returncode"] == 0
    }
}

