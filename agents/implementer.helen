// Implementer Agent v5.2 - 代码实现（TDD循环）

agent Implementer(source_path: str, test_path: str, contract_path: str) {
    description "代码实现师 — 按 TDD 循环编写和修复代码"
    temperature 0.2
    max-turns 20
    tools ["read_file", "write_file", "patch_file", "shell_exec", "path_exists"]

    prompt """
    你是 Helen 代码实现师，按 TDD 循环编写和修复代码。

    源码路径: {{source_path}}
    测试路径: {{test_path}}
    契约路径: {{contract_path}}

    工作流程（严格按 TDD）:
    1. 调用 read_source()、read_tests()、read_contract() 读取所有输入
    2. 对每个测试函数:
       a. 调用 run_single_test() 确认 FAIL（RED）
       b. 调用 apply_patch() 编写最小实现
       c. 调用 verify_after_change() 验证（GREEN）
       d. 如果 FAIL → 回到步骤 b
       e. 如果 PASS → 继续下一个测试
    3. 所有测试通过后，进行重构（REFACTOR）
    4. 验证重构后测试仍 PASS

    Helen 语法注意:
    - `&&` `||` `!` 是逻辑运算符（不是 and/or/not）
    - `substring(s, start, end)` 截取字符串
    - `fn(params): Type { body }` 函数声明
    - `let x = value` 不可变变量, `var x = value` 可变变量
    - `match value { case pattern { expr } default { expr } }` 模式匹配

    返回格式（严格遵守）:
    只返回一个合法的 JSON 对象，不要包含 markdown 代码块、解释文字或任何其他内容。
    {
      "status": "success",
      "implementation": "<完整实现代码>",
      "tests_passed": true/false,
      "iterations": <RED-GREEN 循环次数>,
      "file_path": "{{source_path}}"
    }
    """

    functions {
        fn read_source(): str {
            if !path_exists(source_path) {
                return ""
            }
            return read_file(source_path)
        }

        fn read_tests(): str {
            if !path_exists(test_path) {
                return ""
            }
            return read_file(test_path)
        }

        fn read_contract(): str {
            if !path_exists(contract_path) {
                return ""
            }
            return read_file(contract_path)
        }

        fn apply_patch(file_path: str, old_code: str, new_code: str): map {
            let result = patch_file(file_path, old_code, new_code)
            return json_parse(result)
        }

        fn verify_after_change(file_path: str, test_file: str): map {
            let check = shell_exec("helen check " + file_path + " 2>&1")
            let test = shell_exec("helen test " + test_file + " 2>&1", timeout=120)
            return {
                "check_valid": contains(check, "OK"),
                "check_output": check,
                "test_passed": contains(test, "ALL TESTS PASSED"),
                "test_output": test
            }
        }

        fn run_single_test(test_file: str, test_name: str): map {
            let result = shell_exec("helen test " + test_file + " --filter " + test_name + " 2>&1", timeout=30)
            return {"output": result, "passed": contains(result, "PASSED")}
        }

        fn get_iteration_count(): int {
            // Track how many RED-GREEN cycles we've done
            return 0
        }
    }

    main {
        // 调用 LLM 进行 TDD 循环实现；若 LLM 不可用则优雅降级
        let response = ""
        try {
            response = llm act
        } catch {
            response = ""
        }

        // 防御性解析
        let parsed = {"status": "success", "implementation": "",
                      "tests_passed": false, "iterations": 0, "file_path": ""}
        if response != "" {
            try {
                parsed = json_parse(response)
            } catch {
                let parts = split(response, "```json")
                if len(parts) >= 2 {
                    let inner = split(parts[1], "```")
                    try {
                        parsed = json_parse(inner[0])
                    } catch {
                        parsed = {"status": "success", "implementation": response,
                                  "tests_passed": false, "iterations": 0, "file_path": ""}
                    }
                } else {
                    parsed = {"status": "success", "implementation": response,
                              "tests_passed": false, "iterations": 0, "file_path": ""}
                }
            }
        }
        if parsed["status"] == null { parsed["status"] = "success" }
        if parsed["tests_passed"] == null { parsed["tests_passed"] = false }
        if parsed["iterations"] == null { parsed["iterations"] = 0 }
        return json_stringify(parsed)
    }
}
