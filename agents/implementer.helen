// Implementer Agent v5.2 - 代码实现（TDD循环）

agent Implementer(source_path: str, test_path: str, contract_path: str) {
    description "代码实现师 — TDD 循环编写代码"
    temperature 0.2
    max-turns 5
    tools ["read_file", "write_file", "patch_file", "shell_exec", "path_exists"]

    prompt """
    你是 Helen 代码实现师，按 TDD 循环编写代码。

    源码: {{source_path}}
    测试: {{test_path}}
    契约: {{contract_path}}

    返回 JSON: {"status":"success","implementation":"","tests_passed":false,"iterations":0,"message":""}
    """

    functions {
        fn read_source(): str {
            if !path_exists(source_path) {
                return ""
            }
            return substring(read_file(source_path), 0, 2000)
        }

        fn read_tests(): str {
            if !path_exists(test_path) {
                return ""
            }
            return substring(read_file(test_path), 0, 2000)
        }

        fn read_contract(): str {
            if !path_exists(contract_path) {
                return ""
            }
            return substring(read_file(contract_path), 0, 2000)
        }

        fn apply_patch(file_path: str, old_code: str, new_code: str): map {
            let result = patch_file(file_path, old_code, new_code)
            return json_parse(result)
        }

        fn verify_after_change(file_path: str, test_file: str): map {
            let check = shell_exec("helen check " + file_path + " 2>&1")
            let test = shell_exec("helen test " + test_file + " 2>&1", timeout=60)
            return {
                "check_valid": contains(check, "OK"),
                "check_output": substring(check, 0, 500),
                "test_passed": contains(test, "ALL TESTS PASSED"),
                "test_output": substring(test, 0, 500)
            }
        }

        fn run_single_test(test_file: str, test_name: str): map {
            let result = shell_exec("helen test " + test_file + " --filter " + test_name + " 2>&1", timeout=30)
            return {"output": substring(result, 0, 500), "passed": contains(result, "PASSED")}
        }
    }

    main {
        let source = read_source()
        let tests = read_tests()
        let contract = read_contract()

        return json_stringify({
            "status": "success",
            "implementation": "",
            "tests_passed": false,
            "iterations": 0,
            "message": "Ready for LLM processing"
        })
    }
}
