// TestBuilder Agent v5.2 - 测试生成

agent TestBuilder(source_path: str, contract_path: str) {
    description "测试构建师 — 生成 Helen 测试用例"
    temperature 0.3
    max-turns 5
    tools ["read_file", "write_file", "list_dir", "path_exists"]

    prompt """
    你是 Helen 测试构建师。根据源码和契约生成测试用例。

    源码: {{source_path}}
    契约: {{contract_path}}

    返回 JSON: {"status":"success","test_code":"","test_count":0,"message":""}
    """

    functions {
        fn read_source(): str {
            if !path_exists(source_path) {
                return ""
            }
            return substring(read_file(source_path), 0, 2000)
        }

        fn read_contract(): str {
            if !path_exists(contract_path) {
                return ""
            }
            return substring(read_file(contract_path), 0, 2000)
        }

        fn get_existing_tests(): list {
            let test_files = []
            let files = list_dir(".")
            for f in files {
                if startswith(f, "test_") && endswith(f, ".helen") {
                    test_files.append(f)
                }
            }
            return test_files
        }
    }

    main {
        let source = read_source()
        let contract = read_contract()
        let existing = get_existing_tests()

        return json_stringify({
            "status": "success",
            "test_code": "",
            "test_count": 0,
            "message": "Ready for LLM processing"
        })
    }
}
