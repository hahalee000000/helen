// ============================================================
// TestBuilder Agent - Generate tests from contracts
// ============================================================

import "contracts/contracts.helen"

agent TestBuilder(source_code: str, contract: str) {
    description "测试生成器 — 根据契约和源码生成 Helen 测试用例"
    model "qwen3.7-max"
    temperature 0.3
    max-turns 5
    tools ["read_file", "write_file", "list_dir", "path_exists"]

    prompt """
    你是 Helen 测试生成器。根据契约和源码生成完整的测试用例。

    源码: {{source_code}}
    契约: {{contract}}

    工作流程:
    1. 分析契约中的函数签名和错误码
    2. 为每个函数生成测试用例，覆盖：
       - 正常情况（success）
       - 错误情况（各种 error_code）
       - 边界情况（空值、极值等）
    3. 使用 Helen 测试框架（test_ 开头的函数）
    4. 返回生成的测试代码
    """

    functions {
        fn get_existing_tests(): list {
            let test_files = []
            let files = list_dir(".")
            for file in files {
                if startswith(file, "test_") && endswith(file, ".helen") {
                    test_files.append(file)
                }
            }
            return test_files
        }
    }

    main {
        let existing = get_existing_tests()
        llm act
    }
}
