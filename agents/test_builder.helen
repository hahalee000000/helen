// TestBuilder Agent v5.2 - 测试生成

agent TestBuilder(source_path: str, contract_path: str) {
    description "测试构建师 — 根据契约和源码生成 Helen 测试用例"
    temperature 0.4
    max-turns 5
    tools ["read_file", "write_file", "list_dir", "path_exists"]

    prompt """
    你是 Helen 测试构建师。根据契约和源码生成完整的测试用例。

    源码路径: {{source_path}}
    契约路径: {{contract_path}}

    工作流程:
    1. 调用 read_source() 读取源码
    2. 调用 read_contract() 读取契约
    3. 调用 get_existing_tests() 或 get_existing_tests(path) 了解已有测试
    4. 为契约中的每个函数生成测试，覆盖:
       - 正常情况（success）
       - 错误情况（各种 error_code）
       - 边界情况（空值、极值）
    5. 使用 Helen 测试框架（test_ 开头的函数，assert 断言）
    6. 将测试代码通过 write_file 写入测试文件

    返回格式（严格遵守）:
    只返回一个合法的 JSON 对象，不要包含 markdown 代码块、解释文字或任何其他内容。
    {
      "status": "success",
      "test_code": "<完整测试代码>",
      "test_count": <测试函数数量>,
      "file_path": "<测试文件路径>"
    }
    """

    functions {
        fn read_source(): str {
            if !path_exists(source_path) {
                return ""
            }
            return read_file(source_path)
        }

        fn read_contract(): str {
            if !path_exists(contract_path) {
                return ""
            }
            return read_file(contract_path)
        }

        fn get_existing_tests(path: str = "."): list {
            let test_files = []
            if !path_exists(path) {
                return test_files
            }
            try {
                let files = list_dir(path)
                for file in files {
                    if startswith(file, "test_") && endswith(file, ".helen") {
                        test_files.append(file)
                    }
                }
            } catch {
                // list_dir 失败（权限问题等），返回空列表
            }
            return test_files
        }
    }

    main {
        // 调用 LLM 生成测试用例；若 LLM 不可用则优雅降级
        let response = ""
        try {
            response = llm act
        } catch {
            response = ""
        }

        // 防御性解析
        let parsed = {"status": "success", "test_code": "", "test_count": 0, "file_path": ""}
        if response != "" {
            try {
                parsed = json_parse(response)
            } catch {
                let parts = split(response, "```json")
                if len(parts) >= 2 {
                    let inner = split(parts[1], "```")
                    try {
                        parsed = json_parse(inner[0])
                    } catch {
                        parsed = {"status": "success", "test_code": response, "test_count": 0, "file_path": ""}
                    }
                } else {
                    parsed = {"status": "success", "test_code": response, "test_count": 0, "file_path": ""}
                }
            }
        }
        if parsed["status"] == null { parsed["status"] = "success" }
        if parsed["test_count"] == null { parsed["test_count"] = 0 }
        return json_stringify(parsed)
    }
}
